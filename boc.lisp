(defstruct (ce (:conc-name ce-)) title title-color lines)
(defparameter +codex+
  (vector
   (make-ce :title "THE WESTERN FRONT" :title-color +yel+ :lines '("The Western Front stretches 700 km from the North Sea to Switzerland." "Since the failure of the Schlieffen Plan in 1914, both sides entrenched." "Progress is measured in metres and paid for in thousands of lives." "You command a sector near Passchendaele, Flanders, Belgium." "The mud here is legendary. Men have drowned in shell craters." "Your orders arrive from Brigade HQ twelve miles behind the line." "They have not personally visited the front in three months." "The Somme claimed 57,000 British casualties on its first day alone." "The Third Ypres offensive (Passchendaele) began July 31st, 1917." "Haig believes attrition will break Germany. The men are not consulted."))
   (make-ce :title "TRENCH WARFARE" :title-color +cyn+ :lines '("The front-line trench: a ditch six feet deep and two feet wide." "Duckboards line the floor. Walls shored with corrugated iron." "A fire-step lets men peer over the parapet at stand-to." "Behind: support trenches, reserve trenches, communication lines." "The smell: mud, cordite, decay, latrine, wet wool. Indescribable." "Trench foot afflicts men standing in water without relief." "Rats as large as cats devour rations and gnaw at the sleeping." "Average life expectancy of a second lieutenant: six weeks." "Between attacks: fatigues, carrying parties, digging, sandbagging." "A man can go mad from the waiting as easily as from the shells."))
   (make-ce :title "GAS WARFARE" :title-color +grn+ :lines '("April 1915: the Germans first used chlorine gas at Ypres." "The yellow-green cloud drifted over Allied trenches at dusk." "Men described it as lungs full of fire — drowning from inside." "Phosgene followed: colourless, smelling faintly of cut hay. Deadlier." "Mustard gas, introduced July 1917, blisters skin and blinds eyes." "Mustard gas has no immediate smell. Men often don't know until too late." "A well-drilled unit with Small Box Respirators can survive most attacks." "Without medical supplies a gas attack leaves lasting casualties." "Gas masks fog in cold air and suffocate under exertion." "The sound of the gas alarm — phosgene rattles — haunts veterans for life."))
   (make-ce :title "CAPTAIN ALISTAIR THORNE" :title-color +yel+ :lines '("Captain Alistair Thorne, age 29. 11th Battalion, East Lancashire Regiment." "Born in Preston. Joined Kitchener's New Army voluntarily in August 1914." "Commissioned after the Somme. Three of his original platoon survived." "He does not speak of the Somme. He does not need to." "He writes to his mother every Sunday. Half the letters are returned." "He was mentioned in dispatches once, at Beaumont Wood." "He keeps a photograph of his sister Agnes inside his breast pocket." "His wristwatch stopped during a barrage in April. He has not replaced it." "He still believes in what he is doing. He is no longer certain why." "He is, in all practical terms, the last man standing in his draft."))
   (make-ce :title "SGT. HARRIS — BRAVE" :title-color +red+ :lines '("Sergeant Thomas Harris, age 34. Former coal miner from Wigan." "Volunteered August 1914, driven by genuine and uncomplicated patriotism." "Was at the Gallipoli landings. Does not discuss what he saw there." "His bravery borders on recklessness — volunteers for every night raid." "The men of Alpha Section follow him without hesitation." "He would die for any one of them. They all know it." "A recommendation for the Military Medal is pending at Brigade." "He sharpens his bayonet each evening. He reads no books." "His hands tremble slightly at breakfast. He pours his tea very carefully." "He does not mention the trembling. Neither do the men."))
   (make-ce :title "SGT. MOORE — STEADFAST" :title-color +grn+ :lines '("Sergeant William Moore, age 41. Regular Army since 1897." "Fought in the Second Boer War, the Northwest Frontier, France since 1914." "The most experienced soldier in the company by a considerable margin." "He is the calm eye at the centre of every storm." "Even under the heaviest barrage he moves deliberately, checking men." "He has four daughters at home in Dorset. He writes each weekly." "He has never been wounded. The men consider this extraordinary luck." "His vice: strong tea, guarded jealously from all appropriation." "He has seen enough officers come and go that he does not form attachments." "He respects Captain Thorne. This is rare and means a great deal."))
   (make-ce :title "SGT. LEWIS — DRUNKARD" :title-color +yel+ :lines '("Sergeant Owen Lewis, age 38. Former schoolteacher from Cardiff, Wales." "Joined 1915, commissioned briefly as a second lieutenant." "Demoted following an incident involving a rum store and a court of inquiry." "The incident does not appear in any accessible official record." "He was a fine soldier and a finer man once. The rum ration found him." "He hides bottles inside the sandbag walls. The men pretend not to notice." "On good mornings he recites Keats and Wilfred Owen to the section." "The men listen. They do not always understand. They listen anyway." "He is terrified of dying and more terrified that he deserves to." "He has not had a full night's sleep since the winter of 1915."))
   (make-ce :title "SGT. BELL — COWARDLY" :title-color +mag+ :lines '("Sergeant Arthur Bell, age 26. Bank clerk from Lambeth, London." "Conscripted under the Military Service Act in January 1916." "He did not want to come. He stated this clearly to his tribunal." "His sergeant's stripes came after two better men died in one week." "He freezes under concentrated fire. His men have begun to notice." "He is not a villain. He is a man violently miscast by history." "Privately he writes detailed letters cataloguing his fear." "He sends them to no one. He keeps them in a tin under his bedroll." "He prays every night. He is no longer certain anyone is listening." "He would be good at his former job. He was very good at his former job."))
   (make-ce :title "THE ENEMY — IMPERIAL GERMAN ARMY" :title-color +red+ :lines '("The German Imperial Army: professional, adaptive, formidably supplied." "Their Sturmtruppen (stormtrooper) tactics, developed in 1917, are new." "Infiltration: small groups bypass strongpoints to strike the rear." "German artillery is heavy, accurate, and seemingly inexhaustible." "You rarely see them. They are voices in darkness and metal in daylight." "Some prisoners are boys of sixteen. The war does not discriminate." "German soldiers call no-man's-land 'Niemandsland'. The word is the same." "The German soldier opposite has the same rations, same rats," "same fear. His officers told him the same lies. He holds his line." "This does not make him your enemy any less. It makes it worse."))
   (make-ce :title "MEDICAL CARE IN THE FIELD" :title-color +cyn+ :lines '("Regimental Aid Post: first stop for casualties. One Medical Officer." "Stretcher-bearers carry wounded through open ground under fire." "Casualty Clearing Stations are five miles back — hours away." "Shell shock (neurasthenia) is poorly understood. Most are sent back." "Morphia is scarce. Many receive rum, a pad, and a quiet word." "Your medical supplies: dressings, anti-gas equipment, morphia." "Run out and gas attacks become catastrophic. Disease spreads." "Trench foot: preventable with dry socks and foot inspections." "Wounds left untreated become infected. Men die in days." "Every med spent is a bet that the man is worth saving. He is."))
   (make-ce :title "WEAPONS & MATERIEL" :title-color +yel+ :lines '("Lee-Enfield Mk III: 15 rounds per minute in trained hands." "Pattern 1907 bayonet: 17 inches of steel. The last resort. Used often." "Mills bomb No. 5: essential for raids and close defence." "Lewis gun: light machine gun, 47-round drum. Section's backbone." "Stokes mortar: short range, high arc. Extraordinarily effective." "18-pounder field gun: workhorse of British artillery support." "Ammo represents rounds, bombs, and mortar shells combined." "Running low costs patrols their effectiveness. Men feel naked." "LIBERAL ammo policy maximises combat power. Budget carefully." "CONSERVE policy stretches supply but weakens every engagement."))
   (make-ce :title "RATIONS & SUPPLY" :title-color +grn+ :lines '("A British soldier required 3,000 calories per day in the field." "Bully beef (canned corned beef) and hard tack biscuit were standard." "Tea was not optional. It was as important as ammunition." "Food on HALF rations produces quietly corrosive morale damage." "EMERGENCY rations produce open resentment within 48 hours." "The rum ration (SRD — Services Rum Diluted) was issued at stand-to." "Issued at the captain's discretion. It was always deeply appreciated." "Rats attacked food stores nightly. Eternal vigilance was required." "A good cook (Pte. Whitmore notwithstanding) was worth two riflemen." "The men could endure almost anything if they were fed."))
   (make-ce :title "COMMAND & THE OFFICER'S BURDEN" :title-color +cyn+ :lines '("The company commander stands between men and a distant, abstract war." "His orders come from men who have not seen the front in months." "His decisions — who raids, who rests, who is sacrificed — are real." "Command Points represent the finite reserve of personal authority." "A captain can inspire, cajole, comfort, threaten — but not endlessly." "Issue rum. Write letters for the illiterate. Hold a medal ceremony." "Every act of personal leadership costs something from the commander." "The men do not need a general. They need a captain who knows their names." "Thorne knows all of them. He knows their wives' names. Their children's." "He will carry that weight whether they survive or not."))
   (make-ce :title "TRENCH ENGINEERING" :title-color +mag+ :lines '("The British soldier spent far more time digging than fighting." "Duckboards, drainage sumps, fire-steps: each built by hand and bayonet." "Sandbag revetments absorb shell fragments and reduce casualties." "A well-built dugout provides shelter and raises spirits." "The Lewis gun nest: a sandbagged emplacement for the section weapon." "Signal wire buried in the floor allowed communication under fire." "Trench periscopes — mirrors on a stick — let men observe safely." "The Field Hospital upgrade doubles the value of every medical supply." "The Observation Post reveals threats before they strike." "Build early. Build well. The mud will take everything else."))
   (make-ce :title "NOTABLE MEN — THE RANK AND FILE" :title-color +wht+ :lines '("Behind every statistic is a man with a name." "Pte. Whitmore is a crack shot. He volunteers for sniping duty." "Beecroft keeps a battered recipe book and makes rations edible." "Pte. Morley learned first aid from his mother. He uses it every night." "Darton plays mouth organ after stand-to. The men are grateful." "Pollard can find a use for anything. His pouches are always full." "Stubbs runs messages faster than anyone alive. He is also terrified." "Colby barters cigarettes for rations with the supply wagoners." "Finch shot a German officer at 400 yards in the fog. He does not boast." "These men did not choose this. They chose each other. That is enough."))))
;;; ── Game Structures ──────────────────────────────────────────────
(defconstant +max-squads+    8)
(defconstant +max-msgs+      7)
(defconstant +max-evq+      16)
(defconstant +max-diary+   192)
(defconstant +msg-len+      72)
(defconstant +res-hist-len+ 10)
(defconstant +max-notables+  2)

(defstruct (sgt-s  (:conc-name ss-)) (name "" :type string) (pers 0) (ok 1))
(defstruct (notable-s (:conc-name ns-)) (name "" :type string) (trait 0) (alive 1))
(defstruct (squad-s (:conc-name sq-))
  (name "" :type string) (men 0) (maxm 0) (mor 0) (fat 0) (sick 0)
  (task 0) (has-sgt 0) (sgt (make-sgt-s)) (lore-idx 0) (wounds 0)
  (notables (make-array +max-notables+ :initial-element (make-notable-s)))
  (notable-count 0) (raids-repelled 0) (men-lost 0) (turns-alive 0))
(defstruct (sev-s (:conc-name ev-)) (at 0) (type 0) (food 0) (ammo 0) (meds 0) (tools 0) (men 0))
(defstruct (de-s  (:conc-name de-)) (turn 0) (half-am 0) (text "" :type string))

(defstruct (gs (:conc-name gs-))
  (turn 1) (maxt 84) (half-am 1)
  (weather 0) (agg 40)
  (food 80) (ammo 60) (meds 30) (tools 40)
  (food-max 100) (ammo-max 100)
  (ration-level +ration-full+) (ammo-policy +ammo-normal+)
  (sector-threat (make-array 4 :element-type 'fixnum :initial-element 30))
  (squads (make-array +max-squads+ :initial-element (make-squad-s))) (squad-count 0)
  (msgs (make-array +max-msgs+ :element-type 'string :initial-contents (loop repeat +max-msgs+ collect "")))
  (msg-count 0)
  (diary (make-array +max-diary+ :initial-element (make-de-s))) (diary-count 0)
  (evq (make-array +max-evq+ :initial-element (make-sev-s))) (ev-count 0)
  (hist-fired 0)
  (dispatch-pending -1) (dispatch-done 0) (dispatch-comply 0)
  (convoy-delayed 0) (hq-rep 50) (supply-req-pending -1)
  (res-hist (make-array (list +res-hist-len+ +res-count+) :element-type 'fixnum :initial-element 0))
  (res-hist-count 0)
  (sel 0) (orders-mode 0) (osel 0)
  (cmd-points 2) (upgrades 0)
  (difficulty +diff-normal+)
  (score 0) (medals 0) (forced-standby-turns 0)
  (over +over-none+))

(defvar *g* (make-gs))

;;; ── Save / Load ──────────────────────────────────────────────────
(defconstant +save-magic+   #xB0C1917)
(defconstant +save-version+ 5)
(defconstant +save-slots+   3)
(defparameter +save-names+ #("boc_s0.dat" "boc_s1.dat" "boc_s2.dat"))

(defun save-slot (slot)
  (handler-case
      (with-open-file (f (aref +save-names+ slot) :direction :output :if-exists :supersede :external-format :utf-8)
        (with-standard-io-syntax (let ((*print-readably* t) (*print-circle* t))
          (write (list +save-magic+ +save-version+ *g*) :stream f))) t)
    (error () nil)))

(defun load-slot (slot)
  (handler-case
      (with-open-file (f (aref +save-names+ slot) :direction :input :external-format :utf-8)
        (with-standard-io-syntax
          (let ((data (read f nil nil)))
            (when (and data (= (first data) +save-magic+) (= (second data) +save-version+))
              (setf *g* (third data)) t))))
    (error () nil)))

(defun save-meta-read (slot)
  (handler-case
      (with-open-file (f (aref +save-names+ slot) :direction :input :external-format :utf-8)
        (with-standard-io-syntax
          (let ((data (read f nil nil)))
            (when (and data (= (first data) +save-magic+) (= (second data) +save-version+))
              (let* ((g2 (third data)) (turn (gs-turn g2))
                     (week (1+ (floor (1- turn) 14)))
                     (men (loop for i below (gs-squad-count g2) sum (sq-men (aref (gs-squads g2) i))))
                     (mns #("Jan" "Feb" "Mar" "Apr" "May" "Jun" "Jul" "Aug" "Sep" "Oct" "Nov" "Dec"))
                     (md  #(31 28 31 30 31 30 31 31 30 31 30 31))
                     (days (floor (1- turn) 2)) (mo 0) (d days))
                (loop while (and (< mo 11) (>= d (aref md mo))) do (decf d (aref md mo)) (incf mo))
                (list :used t :label (format nil "Wk ~D  |  ~2D ~A 1917  |  ~D men  |  ~A"
                                             week (1+ d) (aref mns mo) men
                                             (dd-name (aref +diff-defs+ (gs-difficulty g2))))))))))
    (error () nil)))

;;; ── Helpers ──────────────────────────────────────────────────────
(defun dat-str ()
  (let* ((mns #("Jan" "Feb" "Mar" "Apr" "May" "Jun" "Jul" "Aug" "Sep" "Oct" "Nov" "Dec"))
         (md  #(31 28 31 30 31 30 31 31 30 31 30 31))
         (days (floor (1- (gs-turn *g*)) 2)) (mo 0) (d days))
    (loop while (and (< mo 11) (>= d (aref md mo))) do (decf d (aref md mo)) (incf mo))
    (format nil "~2D ~A 1917" (1+ d) (aref mns mo))))
(defun curr-week () (1+ (floor (1- (gs-turn *g*)) 14)))
(defun add-msg (msg)
  (let ((msgs (gs-msgs *g*)))
    (loop for i from (1- +max-msgs+) downto 1 do (setf (aref msgs i) (aref msgs (1- i))))
    (setf (aref msgs 0) (subseq msg 0 (min (length msg) (1- +msg-len+))))
    (when (< (gs-msg-count *g*) +max-msgs+) (incf (gs-msg-count *g*)))))
(defun diary-add (text)
  (when (>= (gs-diary-count *g*) +max-diary+)
    (loop for i from 0 below (1- +max-diary+) do (setf (aref (gs-diary *g*) i) (aref (gs-diary *g*) (1+ i))))
    (setf (gs-diary-count *g*) (1- +max-diary+)))
  (setf (aref (gs-diary *g*) (gs-diary-count *g*))
        (make-de-s :turn (gs-turn *g*) :half-am (gs-half-am *g*)
                   :text (subseq text 0 (min (length text) (1- +msg-len+)))))
  (incf (gs-diary-count *g*)))
(defun log-msg (msg) (add-msg msg) (diary-add msg))
(defun overall-mor ()
  (if (zerop (gs-squad-count *g*)) 0
      (floor (loop for i below (gs-squad-count *g*) sum (sq-mor (aref (gs-squads *g*) i)))
             (gs-squad-count *g*))))
(defun total-men ()   (loop for i below (gs-squad-count *g*) sum (sq-men    (aref (gs-squads *g*) i))))
(defun total-wounds ()(loop for i below (gs-squad-count *g*) sum (sq-wounds (aref (gs-squads *g*) i))))
(defun upg-has (u) (logbitp u (gs-upgrades *g*)))
(defun cp-max ()    (if (upg-has +upg-signal-wire+) 4 3))
(defun food-cap ()  (if (upg-has +upg-food-cache+) 125 100))
(defun ammo-cap ()  (if (upg-has +upg-munitions+)  125 100))
(defun res-get (id)
  (case id (0 (gs-food *g*)) (1 (gs-ammo *g*)) (2 (gs-meds *g*)) (t (gs-tools *g*))))
(defun res-set (id v)
  (case id (0 (setf (gs-food *g*) v)) (1 (setf (gs-ammo *g*) v))
            (2 (setf (gs-meds *g*) v)) (t (setf (gs-tools *g*) v))))
(defun res-cap (id) (case id (0 (food-cap)) (1 (ammo-cap)) (2 50) (t 50)))
(defun find-notable (sq trait)
  (loop for i below (sq-notable-count sq) for n = (aref (sq-notables sq) i)
        when (and (= (ns-trait n) trait) (= (ns-alive n) 1)) do (return n)))
(defun calc-score ()
  (let* ((mul (* (dd-score-mul-x10 (aref +diff-defs+ (gs-difficulty *g*))) 0.1))
         (s (+ (* (gs-turn *g*) 5) (* (total-men) 20) (* (overall-mor) 3)
               (* (gs-medals *g*) 50) (* (floor (gs-hq-rep *g*) 10) 30)
               (* (popcount% (gs-upgrades *g*)) 25))))
    (when (= (gs-over *g*) +over-win+)    (incf s 500))
    (when (= (gs-over *g*) +over-mutiny+) (decf s 200))
    (max 0 (truncate (* s mul)))))
(defun score-grade (sc)
  (cond ((>= sc 1400) "S+") ((>= sc 1000) "S ") ((>= sc 700) "A ")
        ((>= sc 500) "B ")  ((>= sc 300) "C ") ((>= sc 120) "D ") (t "F ")))

;;; ── Initialization ───────────────────────────────────────────────
(defparameter +squad-init+
  #(("Alpha"   7 8 68 25 "Sgt. Harris" 1)
    ("Bravo"   8 8 72 15 "Sgt. Moore"  0)
    ("Charlie" 5 8 44 55 "Sgt. Lewis"  3)
    ("Delta"   6 8 61 40 "Sgt. Bell"   2)))
(defparameter +notable-init+
  #(#(("Pte. Jack" "Whitmore" 0) ("Pte. Tom"  "Beecroft" 1))
    #(("Pte. Alf"  "Morley"   2) ("Pte. Bill" "Darton"   4))
    #(("Pte. Dan"  "Pollard"  3) ("Pte. Fred" "Stubbs"   5))
    #(("Pte. Sam"  "Colby"    1) ("Pte. Ned"  "Finch"    0))))
(defparameter +init-msgs+
  #("Welcome, Captain Thorne. God help us." "ORDERS: Hold the line for 6 weeks."
    "Supply convoy expected in ~3 turns."   "Intelligence: Expect shelling tonight."))

(defun new-game (diff)
  (setf *g* (make-gs :difficulty diff :turn 1 :maxt 84 :half-am 1
                     :weather +weather-clear+ :agg 40
                     :food 80 :ammo 60 :meds 30 :tools 40
                     :ration-level +ration-full+ :ammo-policy +ammo-normal+
                     :cmd-points 2 :dispatch-pending -1 :hq-rep 50 :supply-req-pending -1))
  (loop for i below 4 do (setf (aref (gs-sector-threat *g*) i) (rng-range 20 50)))
  (setf (gs-squad-count *g*) 4)
  (loop for i below 4 do
        (let* ((si (aref +squad-init+ i))
               (arr (make-array +max-notables+)))
          (loop for j below 2 do
                (let* ((nd (aref (aref +notable-init+ i) j)))
                  (setf (aref arr j) (make-notable-s :name (format nil "~A ~A" (nth 0 nd) (nth 1 nd))
                                                     :trait (nth 2 nd) :alive 1))))
          (setf (aref (gs-squads *g*) i)
                (make-squad-s :name (nth 0 si) :men (nth 1 si) :maxm (nth 2 si)
                              :mor (nth 3 si) :fat (nth 4 si) :task +task-standby+ :has-sgt 1
                              :sgt (make-sgt-s :name (nth 5 si) :pers (nth 6 si) :ok 1)
                              :lore-idx (+ 4 i) :notable-count 2 :notables arr))))
  (loop for msg across +init-msgs+ do (log-msg msg))
  (setf (aref (gs-evq *g*) 0) (make-sev-s :at 3 :type +ev-supply+ :food 25 :ammo 20 :meds 8 :tools 5))
  (setf (gs-ev-count *g*) 1))
;;; ── Render Primitives ────────────────────────────────────────────
(defun vbar () (fg% +blu+) (bold%) (write-string +bv+) (rst%))
(defun hline (r kind)
  (at% r 1) (fg% +blu+) (bold%)
  (let* ((sp (string= kind "split")) (jo (string= kind "join")) (cl (string= kind "close-r"))
         (hm (or sp jo cl))
         (lc (if (string= kind "top") +tl+ (if (string= kind "bot") +bl+ +lm+)))
         (rc (if (string= kind "top") +tr+ (if (string= kind "bot") +br+ +rm+)))
         (mc (cond (sp +tm+) (jo +xx+) (cl +bm+) (t ""))))
    (write-string lc)
    (loop for c from 2 below +tw+ do (write-string (if (and hm (= c +div+)) mc +bh+)))
    (write-string rc)) (rst%) (flush%))
(defun draw-box (r1 c1 r2 c2)
  (at% r1 c1) (fg% +blu+) (bold%)
  (write-string +tl+) (loop for i from (1+ c1) below c2 do (write-string +bh+)) (write-string +tr+)
  (loop for r from (1+ r1) below r2 do (at% r c1) (write-string +bv+) (at% r c2) (write-string +bv+))
  (at% r2 c1) (write-string +bl+) (loop for i from (1+ c1) below c2 do (write-string +bh+)) (write-string +br+)
  (rst%) (flush%))
(defun draw-hline-mid (r c1 c2)
  (at% r c1) (fg% +blu+) (bold%) (write-string +lm+)
  (loop for i from (1+ c1) below c2 do (write-string +bh+)) (write-string +rm+) (rst%))

(defun render-resources ()
  (let ((labs #("Food:" "Ammo:" "Meds:" "Tools:"))
        (vals (vector (gs-food *g*) (gs-ammo *g*) (gs-meds *g*) (gs-tools *g*)))
        (maxs (vector (food-cap) (ammo-cap) 50 50))
        (bcs  (vector +grn+ +yel+ +cyn+ +mag+)))
    (loop for i below 4 do
          (let* ((v (aref vals i)) (mx (aref maxs i)) (b (make-bar v mx 10)))
            (at% (+ 4 i) 1) (vbar) (at% (+ 4 i) 2)
            (bold%) (fg% +wht+) (format t " ~6A" (aref labs i)) (rst%)
            (fg% (aref bcs i)) (format t "[~A]" b) (rst%)
            (format t " ~3D/~3D" v mx)
            (when (>= (gs-res-hist-count *g*) 2)
              (let ((cur  (aref (gs-res-hist *g*) (mod (1- (gs-res-hist-count *g*)) +res-hist-len+) i))
                    (prev (aref (gs-res-hist *g*) (mod (- (gs-res-hist-count *g*) 2) +res-hist-len+) i)))
                (cond ((> cur (+ prev 2)) (fg% +grn+) (write-string +sym-up+))
                      ((< cur (- prev 2)) (fg% +red+) (write-string +sym-dn+))
                      (t                  (fg% +gry+) (write-string +sym-eq+))) (rst%))
              (write-char #\Space))
            (loop for j from 26 below +lw+ do (write-char #\Space))
            (at% (+ 4 i) +div+) (vbar) (at% (+ 4 i) (1+ +div+))
            (let ((mi (- (gs-msg-count *g*) 1 i)))
              (if (and (>= mi 0) (< mi (gs-msg-count *g*)) (> (length (aref (gs-msgs *g*) mi)) 0))
                  (progn (fg% +cyn+) (write-string " › ") (rst%)
                         (fg% +wht+) (ppad (aref (gs-msgs *g*) mi) (- +rw+ 3)) (rst%))
                  (dotimes (_ +rw+) (write-char #\Space))))
            (at% (+ 4 i) +tw+) (vbar)))
    (let ((m (overall-mor)) (b (make-bar (overall-mor) 100 8)))
      (at% 8 1) (vbar) (at% 8 2)
      (bold%) (fg% +wht+) (write-string " Moral") (rst%)
      (fg% (mor-color m)) (format t "[~A]~3D%" b m) (rst%)
      (write-char #\Space) (fg% (rd-color (aref +ration-defs+ (gs-ration-level *g*))))
      (format t "R:~A" (rd-name (aref +ration-defs+ (gs-ration-level *g*)))) (rst%)
      (write-char #\Space) (fg% (ad-color (aref +ammo-defs+ (gs-ammo-policy *g*))))
      (format t "A:~A" (ad-name (aref +ammo-defs+ (gs-ammo-policy *g*)))) (rst%)
      (let ((tw (total-wounds))) (when (> tw 0) (write-char #\Space) (fg% +red+) (bold%) (format t "~A~DW" +sym-wn+ tw) (rst%)))
      (loop for i from 39 below +lw+ do (write-char #\Space))
      (at% 8 +div+) (vbar) (at% 8 (1+ +div+))
      (let ((mi4 (if (> (gs-msg-count *g*) 4) (- (gs-msg-count *g*) 5) -1)))
        (if (and (>= mi4 0) (> (length (aref (gs-msgs *g*) mi4)) 0))
            (progn (fg% +cyn+) (write-string " › ") (rst%)
                   (fg% +wht+) (ppad (aref (gs-msgs *g*) mi4) (- +rw+ 3)) (rst%))
            (dotimes (_ +rw+) (write-char #\Space))))
      (at% 8 +tw+) (vbar) (flush%))))

(defun render-squads-map ()
  (let* ((abar (make-bar (gs-agg *g*) 100 9))
         (aln0 (format nil " Aggrn:[~A] ~D%" abar (gs-agg *g*)))
         (ex (if (> (gs-agg *g*) 70) (clamp (floor (gs-agg *g*) 7) 0 14) 0))
         (aln1 (format nil " ~A~A" (make-string ex :initial-element #\!) (if (> (gs-agg *g*) 70) " ATTACK LIKELY" "")))
         (sec-row (format nil " A:~3D B:~3D C:~3D D:~3D" (aref (gs-sector-threat *g*) 0) (aref (gs-sector-threat *g*) 1) (aref (gs-sector-threat *g*) 2) (aref (gs-sector-threat *g*) 3)))
         (upln (let ((s (copy-seq " Upg:"))) (loop for i below +upg-count+ when (upg-has i) do (setf s (concatenate 'string s "[" (aref +upg-shorts+ i) "]"))) s))
         (map (vector "                                   "
                      (concatenate 'string " " (make-string 32 :initial-element #\─) " ")
                      "  [A]  [B]  [C]  [D]   Sectors  "
                      sec-row
                      (concatenate 'string "    " +tl+ (make-string 10 :initial-element #\═) +tr+ "                 ")
                      (concatenate 'string "    " +bv+ "   H.Q.   " +bv+ "  ~~No Man's~~  ")
                      (concatenate 'string "    " +bl+ (make-string 10 :initial-element #\═) +br+ "  ~~  Land   ~~  ")
                      (if (> (gs-upgrades *g*) 0) upln "                                   ")
                      aln0 aln1)))
    (loop for r from 11 to 20 do
          (let* ((mi (- r 11)) (si (floor (- r 11) 2)) (ss (mod (- r 11) 2))
                 (sq (and (< si (gs-squad-count *g*)) (aref (gs-squads *g*) si))))
            (at% r 1) (vbar) (at% r 2)
            (cond
              ((null sq) (dotimes (_ +lw+) (write-char #\Space)))
              ((zerop ss)
               (let* ((sel (= si (gs-sel *g*))) (mb (make-bar (sq-mor sq) 100 7)))
                 (fg% +wht+) (write-string (if sel " ► " "   ")) (rst%)
                 (when sel (bold%)) (fg% (if sel +yel+ +wht+))
                 (format t "~7A" (sq-name sq)) (rst%)
                 (fg% +gry+) (format t "~D/~D" (sq-men sq) (sq-maxm sq)) (rst%)
                 (if (> (sq-wounds sq) 0) (progn (fg% +red+) (format t "+~DW" (sq-wounds sq)) (rst%)) (write-char #\Space))
                 (write-char #\Space)
                 (fg% (mor-color (sq-mor sq))) (format t "[~A]" mb) (rst%)
                 (write-char #\Space)
                 (fg% (td-color (aref +task-defs+ (sq-task sq)))) (bold%)
                 (format t "~7A" (td-name (aref +task-defs+ (sq-task sq)))) (rst%)
                 (loop for i from 33 below +lw+ do (write-char #\Space))))
              (t
               (if (and (= (gs-orders-mode *g*) 1) (= si (gs-sel *g*)))
                   (let* ((n +task-count+) (pv (mod (+ (gs-osel *g*) (1- n)) n)) (nx (mod (1+ (gs-osel *g*)) n)))
                     (fg% +yel+) (bold%) (write-string "  ► ") (rst%)
                     (fg% +gry+) (ppad (td-name (aref +task-defs+ (aref +order-opts+ pv))) 7) (rst%)
                     (write-char #\Space)
                     (fg% +cyn+) (bold%) (format t "[~7A]" (td-name (aref +task-defs+ (aref +order-opts+ (gs-osel *g*))))) (rst%)
                     (write-char #\Space)
                     (fg% +gry+) (ppad (td-name (aref +task-defs+ (aref +order-opts+ nx))) 7) (rst%)
                     (loop for i from 30 below +lw+ do (write-char #\Space)))
                   (let* ((sl (if (= (sq-has-sgt sq) 1)
                                  (format nil "   ~A (~A)" (ss-name (sq-sgt sq)) (pd-name (aref +pers-defs+ (ss-pers (sq-sgt sq)))))
                                  "   No Sergeant"))
                          (fc (if (< (sq-fat sq) 40) +grn+ (if (< (sq-fat sq) 70) +yel+ +red+)))
                          (na (loop for j below (sq-notable-count sq) count (= (ns-alive (aref (sq-notables sq) j)) 1))))
                     (dim%) (fg% +gry+) (ppad sl 30) (rst%)
                     (write-string "Fat:") (fg% fc) (format t "~2D%" (sq-fat sq)) (rst%)
                     (fg% +gry+) (format t " N:~D" na) (rst%)
                     (loop for i from 41 below +lw+ do (write-char #\Space))))))
            (at% r +div+) (vbar) (at% r (1+ +div+))
            (fg% +gry+) (ppad (aref map mi) +rw+) (rst%)
            (at% r +tw+) (vbar)))
    (flush%)))

(defun render ()
  (cls%)
  (hline 1 "top")
  (at% 2 1) (vbar) (at% 2 2)
  (fg% +yel+) (bold%) (write-string " BURDEN OF COMMAND") (rst%)
  (fg% +gry+) (format t " ~A " +vt+) (rst%)
  (fg% +wht+) (write-string (subseq (dat-str) 0 6)) (rst%)
  (fg% (if (= (gs-half-am *g*) 1) +cyn+ +mag+)) (format t " ~A" (if (= (gs-half-am *g*) 1) "AM" "PM")) (rst%)
  (fg% +gry+) (format t " ~A " +vt+) (rst%)
  (fg% (wd-color (aref +weather-defs+ (gs-weather *g*)))) (write-string (wd-label (aref +weather-defs+ (gs-weather *g*)))) (rst%)
  (fg% +gry+) (format t " ~A Wk~D T~D/~D" +vt+ (curr-week) (gs-turn *g*) (gs-maxt *g*))
  (format t " ~A CP:" +vt+) (rst%)
  (loop for i below (cp-max) do
        (if (< i (gs-cmd-points *g*)) (progn (fg% +yel+) (bold%) (write-string +sym-bl+) (rst%))
            (progn (fg% +gry+) (dim%) (write-string +sym-ci+) (rst%))))
  (fg% +gry+) (format t " R:~D" (gs-hq-rep *g*)) (rst%)
  (fg% (dd-color (aref +diff-defs+ (gs-difficulty *g*)))) (dim%)
  (let ((dn (dd-name (aref +diff-defs+ (gs-difficulty *g*))))) (format t " [~A]" (subseq dn 0 (min 3 (length dn))))) (rst%)
  (at% 2 +tw+) (vbar) (flush%)
  (hline 3 "split") (render-resources) (hline 9 "join")
  (at% 10 2) (bold%) (fg% +wht+) (ppad " SQUADS" +lw+) (rst%)
  (at% 10 (1+ +div+)) (bold%) (fg% +wht+) (ppad " SECTOR MAP" +rw+) (rst%)
  (at% 10 1) (vbar) (at% 10 +div+) (vbar) (at% 10 +tw+) (vbar) (flush%)
  (render-squads-map)
  (hline 21 "close-r")
  (at% 22 1) (vbar) (at% 22 2) (fg% +yel+)
  (ppad (if (= (gs-orders-mode *g*) 1)
             (format nil " [~A~A] Cycle  [ENTER] Confirm  [ESC] Cancel" +sym-lf+ +sym-rt+)
             " [SPC] EndTurn  [O] Orders  [C] Cmd  [R] Resources  [I] Intel  [D] Dossier  [ESC] Menu")
        (- +tw+ 2)) (rst%)
  (at% 22 +tw+) (vbar) (flush%) (hline 23 "bot") (at% 24 1) (flush%))
;;; ── Screen: Resources ────────────────────────────────────────────
(defun screen-resources ()
  (let ((tab 0) (bsel 0))
    (loop
      (cls%) (draw-box 1 2 23 79) (at% 1 4) (fg% +yel+) (bold%)
      (format t " RESOURCE MANAGEMENT  ~A  ~A  ~A  HQ Rep: ~D" +vt+ (dat-str) +vt+ (gs-hq-rep *g*)) (rst%)
      (at% 2 4)
      (dolist (pair `((0 " [1] Overview ") (1 " [2] Barter ") (2 " [3] Policies ")))
        (if (= tab (first pair)) (progn (fg% +yel+) (bold%)) (fg% +gry+))
        (write-string (second pair)) (rst%))
      (draw-hline-mid 3 2 79)
      (cond
        ((= tab 0)
         (at% 4 4) (fg% +wht+) (bold%) (write-string " CURRENT STOCK") (rst%)
         (at% 5 4) (fg% +gry+) (dotimes (_ 74) (write-char #\-)) (rst%)
         (loop for i below +res-count+ do
               (let* ((v (res-get i)) (mx (res-cap i)) (bar (make-bar v mx 20))
                      (pct (if (zerop mx) 0.0 (/ v (float mx)))))
                 (at% (+ 6 i) 4) (fg% (aref +res-colors+ i)) (bold%) (format t " ~7A" (aref +res-names+ i)) (rst%)
                 (fg% (aref +res-colors+ i)) (format t "[~A]" bar) (rst%)
                 (format t " ~3D/~3D" v mx) (at% (+ 6 i) 42)
                 (cond ((< pct 0.15) (fg% +red+) (bold%) (write-string " CRITICAL"))
                       ((< pct 0.30) (fg% +red+) (write-string " LOW"))
                       ((< pct 0.60) (fg% +yel+) (write-string " FAIR"))
                       (t            (fg% +grn+) (write-string " GOOD"))) (rst%)))
         (at% 11 4) (fg% +wht+) (bold%) (write-string " TREND  (last 10 turns)") (rst%)
         (at% 12 4) (fg% +gry+) (dotimes (_ 74) (write-char #\-)) (rst%)
         (let ((spark "▁▂▃▄▅▆▇█"))
           (loop for ri below +res-count+ do
                 (at% (+ 13 ri) 4) (fg% (aref +res-colors+ ri)) (format t " ~7A" (aref +res-names+ ri)) (rst%)
                 (let ((n (min (gs-res-hist-count *g*) +res-hist-len+)) (mx (res-cap ri)))
                   (loop for j below +res-hist-len+ do
                         (let ((hi (+ (- (gs-res-hist-count *g*) +res-hist-len+) j)))
                           (if (or (< hi 0) (>= j n)) (write-char #\Space)
                               (write-char (char spark (clamp (truncate (* (/ (aref (gs-res-hist *g*) (mod hi +res-hist-len+) ri) mx) 7)) 0 7))))))
                   (when (>= n 2)
                     (let ((cur  (aref (gs-res-hist *g*) (mod (1- (gs-res-hist-count *g*)) +res-hist-len+) ri))
                           (prev (aref (gs-res-hist *g*) (mod (- (gs-res-hist-count *g*) 2) +res-hist-len+) ri)))
                       (cond ((> cur (+ prev 2)) (fg% +grn+) (format t " ~A" +sym-up+))
                             ((< cur (- prev 2)) (fg% +red+) (format t " ~A" +sym-dn+))
                             (t                  (fg% +gry+) (format t " ~A" +sym-eq+))) (rst%))))))
         (at% 18 4) (fg% +wht+) (bold%) (write-string " WOUNDED PERSONNEL") (rst%)
         (at% 19 4) (fg% +gry+) (dotimes (_ 74) (write-char #\-)) (rst%)
         (at% 20 4) (let ((any 0))
           (loop for i below (gs-squad-count *g*) do
                 (let ((sq (aref (gs-squads *g*) i)))
                   (when (> (sq-wounds sq) 0) (fg% +red+) (format t " ~A:~DW" (sq-name sq) (sq-wounds sq)) (rst%) (incf any))))
           (when (zerop any) (fg% +grn+) (write-string " No walking wounded.") (rst%)))
         (at% 21 4) (fg% +wht+) (bold%) (write-string " SECTOR THREATS") (rst%)
         (at% 22 4)
         (loop for i below 4 do
               (let* ((t% (aref (gs-sector-threat *g*) i)) (col (if (>= t% 70) +red+ (if (>= t% 40) +yel+ +grn+))))
                 (fg% col) (format t "  [~A] ~3D%" (aref #("A" "B" "C" "D") i) t%) (rst%))))
        ((= tab 1)
         (at% 4 4) (fg% +wht+) (bold%) (write-string " RESOURCE EXCHANGE  (barter with field traders and salvage teams)") (rst%)
         (at% 5 4) (fg% +gry+) (dotimes (_ 74) (write-char #\-)) (rst%)
         (loop for i below (length +barter-rates+) do
               (let* ((b (aref +barter-rates+ i)) (can (>= (res-get (br-from b)) (br-give b))) (row (+ 6 i)))
                 (when (<= row 21)
                   (at% row 4)
                   (cond ((and (= i bsel) can) (fg% +yel+) (bold%) (write-string "► "))
                         ((= i bsel) (fg% +gry+) (write-string "► ")) (t (write-string "  ")))
                   (if can (fg% (aref +res-colors+ (br-from b))) (progn (dim%) (fg% +gry+)))
                   (format t "~6A" (aref +res-names+ (br-from b))) (rst%)
                   (fg% +gry+) (format t " -~2D " (br-give b)) (rst%) (write-string +sym-rt+)
                   (fg% (aref +res-colors+ (br-to b))) (format t " ~6A" (aref +res-names+ (br-to b))) (rst%)
                   (fg% +gry+) (format t " +~2D  " (br-get b)) (rst%)
                   (when (= i bsel) (fg% +wht+) (dim%) (ppad (br-desc b) 40) (rst%))))))
        (t
         (at% 4 4) (fg% +wht+) (bold%) (write-string " RATION POLICY") (rst%)
         (at% 5 4) (fg% +gry+) (dotimes (_ 74) (write-char #\-)) (rst%)
         (loop for i below +ration-count+ do
               (let* ((r (aref +ration-defs+ i)) (sel (= (gs-ration-level *g*) i)))
                 (at% (+ 6 i) 4)
                 (if sel (progn (fg% (rd-color r)) (bold%) (write-string "► ")) (progn (fg% +gry+) (write-string "  ")))
                 (fg% (rd-color r)) (format t "~12A" (rd-name r)) (rst%)
                 (fg% (if sel +wht+ +gry+)) (format t " Food×~4,2F  MorDelta: ~+D/turn  " (rd-food-mul r) (rd-mor-per-turn r))
                 (dim%) (write-string (rd-desc r)) (rst%)))
         (at% 11 4) (fg% +wht+) (bold%) (write-string " AMMO POLICY") (rst%)
         (at% 12 4) (fg% +gry+) (dotimes (_ 74) (write-char #\-)) (rst%)
         (loop for i below +ammo-count+ do
               (let* ((a (aref +ammo-defs+ i)) (sel (= (gs-ammo-policy *g*) i)))
                 (at% (+ 13 i) 4)
                 (if sel (progn (fg% (ad-color a)) (bold%) (write-string "► ")) (progn (fg% +gry+) (write-string "  ")))
                 (fg% (ad-color a)) (format t "~10A" (ad-name a)) (rst%)
                 (fg% (if sel +wht+ +gry+))
                 (format t " Ammo×~4,2F  Patrol×~4,2F  Raid~+3,0F%%  " (ad-ammo-mul a) (ad-patrol-mor-mul a) (* (ad-raid-resist-add a) 100))
                 (dim%) (ppad (ad-desc a) 28) (rst%)))
         (at% 17 4) (fg% +wht+) (bold%) (write-string " WOUND TREATMENT PROTOCOL") (rst%)
         (at% 18 4) (fg% +gry+) (dotimes (_ 74) (write-char #\-)) (rst%)
         (at% 19 4) (fg% +wht+) (write-string " Walking wounded consume 1 med/turn passively.") (rst%)
         (at% 20 4) (fg% +wht+) (write-string " Untreated wounds after 5 turns become fatal (-1 man).") (rst%)
         (at% 21 4) (if (upg-has +upg-field-hosp+)
                        (progn (fg% +grn+) (write-string " Field Hospital: heals 1 extra wound/turn automatically."))
                        (progn (fg% +gry+) (write-string " Field Hospital not built (use Trench Upgrades to build)."))) (rst%)))
      (draw-hline-mid 22 2 79)
      (cond ((= tab 1) (at% 22 5) (fg% +yel+) (format t "[~A~A] Select  [ENTER] Execute  [1/2/3] Tabs  [ESC] Back" +sym-up+ +sym-dn+) (rst%))
            ((= tab 2) (at% 22 5) (fg% +yel+) (format t "[~A~A] Change ration/ammo policy  [1/2/3] Tabs  [ESC] Back" +sym-up+ +sym-dn+) (rst%))
            (t         (at% 22 5) (fg% +yel+) (write-string "[1/2/3] Tabs  [ESC] Back") (rst%)))
      (flush%)
      (let ((k (read-key)))
        (when (or (eq k :esc) (eq k :Q)) (return))
        (when (eq k :|1|) (setf tab 0)) (when (eq k :|2|) (setf tab 1)) (when (eq k :|3|) (setf tab 2))
        (cond
          ((= tab 1)
           (when (eq k :up)   (setf bsel (mod (+ bsel (1- (length +barter-rates+))) (length +barter-rates+))))
           (when (eq k :down) (setf bsel (mod (1+ bsel) (length +barter-rates+))))
           (when (eq k :enter)
             (let* ((b (aref +barter-rates+ bsel)) (fv (res-get (br-from b))))
               (when (>= fv (br-give b))
                 (res-set (br-from b) (- fv (br-give b)))
                 (res-set (br-to b) (clamp (+ (res-get (br-to b)) (br-get b)) 0 (res-cap (br-to b))))
                 (log-msg (format nil "Barter: -~D ~A +~D ~A." (br-give b) (aref +res-names+ (br-from b)) (br-get b) (aref +res-names+ (br-to b))))))))
          ((= tab 2)
           (when (eq k :up)    (setf (gs-ration-level *g*) (clamp (1+ (gs-ration-level *g*)) 0 (1- +ration-count+))))
           (when (eq k :down)  (setf (gs-ration-level *g*) (clamp (1- (gs-ration-level *g*)) 0 (1- +ration-count+))))
           (when (eq k :left)  (setf (gs-ammo-policy  *g*) (clamp (1- (gs-ammo-policy *g*))  0 (1- +ammo-count+))))
           (when (eq k :right) (setf (gs-ammo-policy  *g*) (clamp (1+ (gs-ammo-policy *g*))  0 (1- +ammo-count+))))))))))

;;; ── Screen: Command ──────────────────────────────────────────────
(defun screen-command ()
  (let ((sel 0))
    (loop
      (cls%) (draw-box 2 5 22 75) (at% 2 7) (fg% +yel+) (bold%)
      (format t " COMMAND ACTIONS  ~A  Capt. Thorne  ~A  CP: ~D/~D  ~A  Rep: ~D" +vt+ +vt+ (gs-cmd-points *g*) (cp-max) +vt+ (gs-hq-rep *g*))
      (rst%) (draw-hline-mid 3 5 75)
      (loop for i below +cmd-count+ do
            (let* ((c (aref +cmd-defs+ i))
                   (rum-free (and (= i +cmd-rum+) (upg-has +upg-rum-store+)))
                   (mc (if (and (= i +cmd-medical+) (upg-has +upg-field-hosp+)) (floor (+ (cd-meds-cost c) 1) 2) (cd-meds-cost c)))
                   (sq (and (< (gs-sel *g*) (gs-squad-count *g*)) (aref (gs-squads *g*) (gs-sel *g*))))
                   (can (and (>= (gs-cmd-points *g*) (if rum-free 0 (cd-cp-cost c)))
                             (>= (gs-food *g*) (cd-food-cost c)) (>= (gs-meds *g*) mc)
                             (not (and (= i +cmd-treat-wounded+) (or (null sq) (zerop (sq-wounds sq)))))))
                   (row (+ 4 (* i 2))) (s (= i sel)))
              (at% row 8)
              (cond ((not can) (dim%) (fg% +gry+)) (s (fg% +yel+) (bold%)) (t (fg% +wht+)))
              (format t "~A ~22A" (if s "► " "  ") (cd-name c)) (rst%)
              (when (and (> (cd-cp-cost c) 0) (not rum-free)) (fg% +yel+) (format t "[~DCP]" (cd-cp-cost c)) (rst%))
              (when (> (cd-food-cost c) 0) (fg% +grn+) (format t "[-~DF]" (cd-food-cost c)) (rst%))
              (when (> mc 0) (fg% +cyn+) (format t "[-~DM]" mc) (rst%))
              (when s (at% (1+ row) 10) (dim%) (fg% +gry+) (write-string (cd-effect c)) (rst%))))
      (draw-hline-mid (+ 4 (* +cmd-count+ 2) -1) 5 75)
      (let ((sq (and (< (gs-sel *g*) (gs-squad-count *g*)) (aref (gs-squads *g*) (gs-sel *g*)))))
        (at% (+ 4 (* +cmd-count+ 2)) 8) (fg% +yel+)
        (format t "[~A~A] Select  [ENTER] Execute on ~A  [ESC] Back" +sym-up+ +sym-dn+ (if sq (sq-name sq) "???"))
        (rst%) (flush%)
        (let ((k (read-key)))
          (when (or (eq k :esc) (eq k :Q)) (return))
          (when (eq k :up)   (setf sel (mod (+ sel (1- +cmd-count+)) +cmd-count+)))
          (when (eq k :down) (setf sel (mod (1+ sel) +cmd-count+)))
          (when (and (eq k :enter) sq)
            (let* ((c (aref +cmd-defs+ sel)) (rum-free (and (= sel +cmd-rum+) (upg-has +upg-rum-store+)))
                   (mc (if (and (= sel +cmd-medical+) (upg-has +upg-field-hosp+)) (floor (+ (cd-meds-cost c) 1) 2) (cd-meds-cost c)))
                   (can (and (>= (gs-cmd-points *g*) (if rum-free 0 (cd-cp-cost c)))
                             (>= (gs-food *g*) (cd-food-cost c)) (>= (gs-meds *g*) mc)
                             (not (and (= sel +cmd-treat-wounded+) (zerop (sq-wounds sq)))))))
              (when can
                (unless rum-free (setf (gs-cmd-points *g*) (clamp (- (gs-cmd-points *g*) (cd-cp-cost c)) 0 (cp-max))))
                (decf (gs-food *g*) (cd-food-cost c)) (decf (gs-meds *g*) mc)
                (log-msg (case sel
                  (#.+cmd-rum+           (setf (sq-mor sq) (clamp (+ (sq-mor sq) 15) 0 100)) (format nil "Rum ration: ~A Sq +15 morale." (sq-name sq)))
                  (#.+cmd-letters+       (setf (sq-mor sq) (clamp (+ (sq-mor sq) 10) 0 100)) (format nil "Letters home: ~A Sq +10 morale." (sq-name sq)))
                  (#.+cmd-medical+       (setf (sq-fat sq) (clamp (- (sq-fat sq) 25) 0 100)) (format nil "Triage: ~A Sq fatigue reduced." (sq-name sq)))
                  (#.+cmd-reprimand+     (setf (sq-fat sq) (clamp (- (sq-fat sq) 8) 0 100)) (setf (sq-mor sq) (clamp (- (sq-mor sq) 5) 0 100)) (format nil "Inspection: ~A Sq disciplined." (sq-name sq)))
                  (#.+cmd-speech+        (loop for i below (gs-squad-count *g*) do (setf (sq-mor (aref (gs-squads *g*) i)) (clamp (+ (sq-mor (aref (gs-squads *g*) i)) 8) 0 100))) "Officer's speech: company morale rises.")
                  (#.+cmd-rations-extra+ (loop for i below (gs-squad-count *g*) do (setf (sq-fat (aref (gs-squads *g*) i)) (clamp (- (sq-fat (aref (gs-squads *g*) i)) 15) 0 100))) "Emergency rations: all fatigue reduced.")
                  (#.+cmd-ceremony+      (setf (sq-mor sq) (clamp (+ (sq-mor sq) 20) 0 100)) (incf (gs-medals *g*)) (format nil "Medal ceremony: ~A Sq. +1 commendation." (sq-name sq)))
                  (#.+cmd-leave+         (when (> (sq-men sq) 1) (decf (sq-men sq)) (incf (sq-men-lost sq))) (setf (sq-mor sq) (clamp (+ (sq-mor sq) 15) 0 100)) (format nil "Comp. leave: ~A Sq -1 man +15 morale." (sq-name sq)))
                  (#.+cmd-treat-wounded+ (let ((h (clamp (sq-wounds sq) 0 2))) (setf (sq-wounds sq) (clamp (- (sq-wounds sq) h) 0 (sq-men sq))) (format nil "Treatment: ~D wound(s) treated in ~A Sq." h (sq-name sq))))
                  (#.+cmd-supply-req+
                   (if (< (gs-supply-req-pending *g*) 0)
                       (let* ((eta (+ (gs-turn *g*) (rng-range 5 10))) (q (if (>= (gs-hq-rep *g*) 70) 1 0))
                              (ev (make-sev-s :at eta :type +ev-supply+
                                    :food (rng-range (if (= q 1) 20 10) (if (= q 1) 35 20))
                                    :ammo (rng-range (if (= q 1) 15  8) (if (= q 1) 25 15))
                                    :meds (rng-range (if (= q 1)  6  3) (if (= q 1) 12  8))
                                    :tools(rng-range (if (= q 1)  4  2) (if (= q 1)  8  5)))))
                         (when (< (gs-ev-count *g*) +max-evq+) (setf (aref (gs-evq *g*) (gs-ev-count *g*)) ev) (incf (gs-ev-count *g*)))
                         (setf (gs-supply-req-pending *g*) eta)
                         (format nil "Supply request filed. ETA ~D turns." (- eta (gs-turn *g*))))
                       "Supply request already pending."))
                  (t "Action complete.")))))))))))

;;; ── Screen: Upgrades ─────────────────────────────────────────────
(defun screen-upgrades ()
  (let ((sel 0))
    (loop
      (cls%) (draw-box 2 4 22 77) (at% 2 6) (fg% +mag+) (bold%)
      (format t " TRENCH ENGINEERING  ~A  Tools: ~D" +vt+ (gs-tools *g*)) (rst%)
      (draw-hline-mid 3 4 77)
      (loop for i below +upg-count+ do
            (let* ((u (aref +upg-defs+ i)) (owned (upg-has i)) (can (and (not owned) (>= (gs-tools *g*) (ud-tools-cost u)))) (row (+ 4 (* i 2))))
              (when (<= row 20)
                (at% row 7)
                (cond (owned  (fg% +grn+) (bold%) (format t "  [~A] ~22A" +sym-ck+ (ud-name u)))
                      ((and (= i sel) can) (fg% +yel+) (bold%) (format t "► [~2D~A] ~22A" (ud-tools-cost u) +sym-hts+ (ud-name u)))
                      ((= i sel) (fg% +red+) (format t "► [~2D~A] ~22A" (ud-tools-cost u) +sym-hts+ (ud-name u)))
                      (t (fg% +gry+) (dim%) (format t "  [~2D~A] ~22A" (ud-tools-cost u) +sym-hts+ (ud-name u))))
                (rst%)
                (when (or (= i sel) owned) (fg% (if (= i sel) +wht+ +grn+)) (dim%) (write-string (ud-passive u)) (rst%)))))
      (draw-hline-mid 20 4 77)
      (at% 21 7) (fg% +yel+) (format t "[~A~A] Select  [ENTER] Build  [ESC] Back" +sym-up+ +sym-dn+) (rst%) (flush%)
      (let ((k (read-key)))
        (when (or (eq k :esc) (eq k :Q)) (return))
        (when (eq k :up)   (setf sel (mod (+ sel (1- +upg-count+)) +upg-count+)))
        (when (eq k :down) (setf sel (mod (1+ sel) +upg-count+)))
        (when (eq k :enter)
          (let ((u (aref +upg-defs+ sel)))
            (when (and (not (upg-has sel)) (>= (gs-tools *g*) (ud-tools-cost u)))
              (decf (gs-tools *g*) (ud-tools-cost u))
              (setf (gs-upgrades *g*) (logior (gs-upgrades *g*) (ash 1 sel)))
              (log-msg (format nil "Built: ~A. ~A" (ud-name u) (ud-passive u))))))))))

;;; ── Screen: HQ Dispatch ──────────────────────────────────────────
(defun screen-hq-dispatch (idx)
  (let ((d (aref +hq-dispatches+ idx)) (sel 0))
    (loop
      (cls%) (draw-box 2 4 22 77) (at% 2 6) (fg% +red+) (bold%)
      (format t " ~A  ~A  ~A " +sym-wn+ (hd-title d) +sym-wn+) (rst%)
      (draw-hline-mid 3 4 77)
      (let ((r 5)) (dolist (line (hd-body d)) (when (<= r 13) (at% r 7) (fg% +wht+) (write-string line) (rst%) (incf r))))
      (draw-hline-mid 14 4 77)
      (at% 15 7) (if (= sel 0) (progn (fg% +grn+) (bold%) (format t "  ► ~A" (hd-comply-label d))) (progn (fg% +gry+) (format t "    ~A" (hd-comply-label d)))) (rst%)
      (at% 16 9) (dim%) (fg% +gry+) (write-string (hd-comply-result d)) (rst%)
      (at% 17 7) (if (= sel 1) (progn (fg% +red+) (bold%) (format t "  ► ~A" (hd-defy-label d))) (progn (fg% +gry+) (format t "    ~A" (hd-defy-label d)))) (rst%)
      (at% 18 9) (dim%) (fg% +gry+) (write-string (hd-defy-result d)) (rst%)
      (at% 19 7) (fg% +yel+) (format t "Rep effect: Comply ~+D  /  Defy ~+D" (hd-cy-rep-delta d) (hd-df-rep-delta d)) (rst%)
      (draw-hline-mid 20 4 77)
      (at% 21 7) (fg% +yel+) (format t "[~A~A] Choose  [ENTER] Execute" +sym-up+ +sym-dn+) (rst%) (flush%)
      (let ((k (read-key)))
        (when (or (eq k :up) (eq k :down)) (setf sel (- 1 sel)))
        (when (eq k :enter) (return (- 1 sel)))))))

;;; ── Screen: Intel ────────────────────────────────────────────────
(defun screen-intel ()
  (cls%) (draw-box 1 2 24 79)
  (at% 1 4) (fg% +cyn+) (bold%)
  (format t " INTEL REPORT  ~A  ~A  ~A  T:~D  ~A  Rep:~D" +vt+ (dat-str) +vt+ (gs-turn *g*) +vt+ (gs-hq-rep *g*)) (rst%)
  (loop for r from 2 to 23 do (at% r 40) (fg% +blu+) (bold%) (write-string +bv+) (rst%))
  (draw-hline-mid 2 2 79)
  (at% 3 3) (fg% +wht+) (bold%) (write-string " QUEUE & DISPATCHES") (rst%)
  (at% 4 3) (fg% +gry+) (dotimes (_ 37) (write-char #\-)) (rst%)
  (let ((lr 5))
    (loop for i below (gs-ev-count *g*) while (<= lr 10) do
          (let* ((e (aref (gs-evq *g*) i)) (eta (- (ev-at e) (gs-turn *g*))))
            (at% lr 4)
            (cond ((= (ev-type e) +ev-supply+)    (fg% +grn+) (format t " Supply: T~3D  (in ~D turn~A)" (ev-at e) eta (if (= eta 1) "" "s")))
                  ((= (ev-type e) +ev-reinforce+) (fg% +cyn+) (format t " Reinforce: T~3D  (in ~D turn~A)" (ev-at e) eta (if (= eta 1) "" "s"))))
            (rst%) (incf lr)))
    (when (> (gs-supply-req-pending *g*) 0)
      (at% lr 4) (fg% +yel+) (format t " HQ request: T~3D" (gs-supply-req-pending *g*)) (rst%)))
  (at% 11 3) (fg% +yel+) (bold%) (write-string " UPCOMING HQ ORDERS") (rst%)
  (at% 12 3) (fg% +gry+) (dotimes (_ 37) (write-char #\-)) (rst%)
  (let ((dr 13))
    (loop for i below (length +hq-dispatches+) while (<= dr 17) do
          (when (and (zerop (logand (gs-dispatch-done *g*) (ash 1 i)))
                     (>= (- (hd-turn (aref +hq-dispatches+ i)) (gs-turn *g*)) 0))
            (at% dr 4) (fg% +yel+) (format t " T~3D: ~A" (hd-turn (aref +hq-dispatches+ i)) (subseq (hd-title (aref +hq-dispatches+ i)) 0 (min 32 (length (hd-title (aref +hq-dispatches+ i)))))) (rst%) (incf dr))))
  (at% 18 3) (fg% +mag+) (bold%) (write-string " FIELD NOTES") (rst%)
  (at% 19 3) (fg% +gry+) (dotimes (_ 37) (write-char #\-)) (rst%)
  (let ((hr 20))
    (loop for i below (length +hist-events+) while (<= hr 22) do
          (when (zerop (logand (gs-hist-fired *g*) (ash 1 i)))
            (let ((eta (- (he-turn (aref +hist-events+ i)) (gs-turn *g*))))
              (when (and (>= eta 0) (<= eta 10))
                (at% hr 4) (fg% +gry+) (dim%) (format t " T~3D: ~A" (he-turn (aref +hist-events+ i)) (subseq (he-text (aref +hist-events+ i)) 0 (min 34 (length (he-text (aref +hist-events+ i)))))) (rst%) (incf hr))))))
  (at% 3 42) (fg% +wht+) (bold%) (write-string " ENEMY & SECTOR STATUS") (rst%)
  (at% 4 42) (fg% +gry+) (dotimes (_ 37) (write-char #\-)) (rst%)
  (at% 5 42) (fg% +wht+) (write-string " Aggression: ")
  (fg% (if (> (gs-agg *g*) 70) +red+ (if (> (gs-agg *g*) 40) +yel+ +grn+)))
  (format t "~3D%% [~A]" (gs-agg *g*) (make-bar (gs-agg *g*) 100 14)) (rst%)
  (at% 6 42) (fg% +wht+) (write-string " Weather  : ") (fg% (wd-color (aref +weather-defs+ (gs-weather *g*)))) (write-string (wd-label (aref +weather-defs+ (gs-weather *g*)))) (rst%)
  (at% 7 42) (fg% +gry+) (dim%) (format t "  ~A" (wfx-note (aref +weather-fx+ (gs-weather *g*)))) (rst%)
  (at% 8 42) (fg% +wht+) (bold%) (write-string " Sector threats:") (rst%)
  (loop for i below 4 do
        (let* ((t% (aref (gs-sector-threat *g*) i)) (col (if (>= t% 70) +red+ (if (>= t% 40) +yel+ +grn+))))
          (at% (+ 9 i) 43) (fg% col) (format t " [~A] ~3D%% [~A]" (aref #("A" "B" "C" "D") i) t% (make-bar t% 100 7)) (rst%)))
  (at% 14 42) (fg% +wht+) (bold%) (write-string " RESOURCE FORECAST") (rst%)
  (at% 15 42) (fg% +gry+) (dotimes (_ 37) (write-char #\-)) (rst%)
  (let* ((fm (* (dd-food-mul (aref +diff-defs+ (gs-difficulty *g*))) (rd-food-mul (aref +ration-defs+ (gs-ration-level *g*)))))
         (fc (+ (truncate (+ (* (clamp (floor (total-men) 6) 1 99) fm) 0.5)) (wfx-food-extra (aref +weather-fx+ (gs-weather *g*)))))
         (am (ad-ammo-mul (aref +ammo-defs+ (gs-ammo-policy *g*))))
         (ac (loop for i below (gs-squad-count *g*) sum (truncate (+ (* (td-ammo-cost (aref +task-defs+ (sq-task (aref (gs-squads *g*) i)))) am) 0.5))))
         (tg (loop for i below (gs-squad-count *g*) sum (td-tools-gain (aref +task-defs+ (sq-task (aref (gs-squads *g*) i))))))
         (fg-gain (loop for i below (gs-squad-count *g*) sum (td-food-gain (aref +task-defs+ (sq-task (aref (gs-squads *g*) i))))))
         (ag-gain (loop for i below (gs-squad-count *g*) sum (td-ammo-gain (aref +task-defs+ (sq-task (aref (gs-squads *g*) i)))))))
    (at% 16 43) (fg% +grn+) (format t " Food  ~3D → ~~~3D (~+D)" (gs-food *g*) (clamp (+ (gs-food *g*) fg-gain (- fc)) 0 (food-cap)) (- fg-gain fc)) (rst%)
    (at% 17 43) (fg% +yel+) (format t " Ammo  ~3D → ~~~3D (~+D)" (gs-ammo *g*) (clamp (+ (gs-ammo *g*) ag-gain (- ac)) 0 (ammo-cap)) (- ag-gain ac)) (rst%)
    (at% 18 43) (fg% +cyn+) (format t " Meds  ~3D → ~~~3D (~+D)" (gs-meds *g*) (clamp (- (gs-meds *g*) (total-wounds)) 0 50) (- (total-wounds))) (rst%)
    (at% 19 43) (fg% +mag+) (format t " Tools ~3D → ~~~3D (~+D)" (gs-tools *g*) (clamp (+ (gs-tools *g*) tg) 0 50) tg) (rst%))
  (at% 21 42) (fg% +wht+) (bold%) (write-string " TRENCH STATUS") (rst%) (at% 22 42)
  (let ((uc 0))
    (loop for i below +upg-count+ do (when (upg-has i) (fg% +grn+) (format t " ~A" (ud-name (aref +upg-defs+ i))) (rst%) (incf uc)))
    (when (zerop uc) (fg% +gry+) (write-string " No upgrades built.") (rst%)))
  (at% 24 4) (fg% +yel+) (write-string "[ESC] Back to command") (rst%) (flush%)
  (read-key))
;;; ── Screen: Dossier ──────────────────────────────────────────────
(defun screen-dossier (start-idx)
  (when (or (< start-idx 0) (>= start-idx (gs-squad-count *g*))) (return-from screen-dossier))
  (let ((idx start-idx))
    (loop
      (let ((sq (aref (gs-squads *g*) idx)))
        (cls%) (draw-box 1 2 23 79) (at% 1 4) (fg% +yel+) (bold%)
        (format t " DOSSIER: ~A Section  ~A  ~A  ~A  Sgt: ~A" (sq-name sq) +vt+ (pd-name (aref +pers-defs+ (ss-pers (sq-sgt sq)))) +vt+ (if (= (sq-has-sgt sq) 1) (ss-name (sq-sgt sq)) "None")) (rst%)
        (loop for r from 2 to 22 do (at% r 40) (fg% +blu+) (bold%) (write-string +bv+) (rst%))
        (draw-hline-mid 2 2 79)
        (at% 3 3) (fg% +wht+) (bold%) (write-string " SQUAD STATUS") (rst%)
        (at% 4 3) (fg% +gry+) (dotimes (_ 37) (write-char #\-)) (rst%)
        (at% 5 3) (fg% +wht+) (format t " Strength : ~D/~D [~A]" (sq-men sq) (sq-maxm sq) (make-bar (sq-men sq) (sq-maxm sq) 12)) (rst%)
        (at% 6 3) (fg% +wht+) (format t " Morale   : ~3D%% [~A] " (sq-mor sq) (make-bar (sq-mor sq) 100 12)) (fg% (mor-color (sq-mor sq))) (write-string (mor-label (sq-mor sq))) (rst%)
        (at% 7 3) (fg% +wht+) (format t " Fatigue  : ~3D%% [~A]" (sq-fat sq) (make-bar (sq-fat sq) 100 12)) (rst%)
        (at% 8 3) (fg% +wht+) (format t " Wounds   : ~D walking wounded" (sq-wounds sq)) (when (> (sq-wounds sq) 0) (fg% +red+) (write-string " (!)")) (rst%)
        (at% 9 3) (fg% +wht+) (write-string " Task     : ") (fg% (td-color (aref +task-defs+ (sq-task sq)))) (bold%) (write-string (td-name (aref +task-defs+ (sq-task sq)))) (rst%) (dim%) (fg% +gry+) (format t "  ~A" (td-desc (aref +task-defs+ (sq-task sq)))) (rst%)
        (at% 10 3) (fg% +gry+) (dotimes (_ 37) (write-char #\-)) (rst%)
        (at% 11 3) (fg% +wht+) (bold%) (write-string " NOTABLE MEN") (rst%)
        (loop for j below (sq-notable-count sq) do
              (let ((n (aref (sq-notables sq) j)))
                (at% (+ 12 j) 3)
                (if (= (ns-alive n) 0) (progn (fg% +gry+) (dim%) (format t " ~A  [KIA]" (ns-name n)) (rst%))
                    (progn (fg% (trd-color (aref +trait-defs+ (ns-trait n)))) (format t " ~A" (ns-name n)) (rst%) (fg% +gry+) (dim%) (format t "  [~A] ~A" (trd-name (aref +trait-defs+ (ns-trait n))) (trd-effect (aref +trait-defs+ (ns-trait n)))) (rst%)))))
        (at% 14 3) (fg% +gry+) (dotimes (_ 37) (write-char #\-)) (rst%)
        (at% 15 3) (fg% +wht+) (bold%) (write-string " COMBAT RECORD") (rst%)
        (at% 16 3) (fg% +gry+) (write-string " Raids repelled: ") (fg% +grn+) (format t "~D" (sq-raids-repelled sq)) (rst%)
        (at% 17 3) (fg% +gry+) (write-string " Men lost      : ") (fg% +red+) (format t "~D" (sq-men-lost sq)) (rst%)
        (at% 18 3) (fg% +gry+) (write-string " Turns in line : ") (fg% +cyn+) (format t "~D" (sq-turns-alive sq)) (rst%)
        (at% 19 3) (fg% +wht+) (write-string " Sgt status: ")
        (cond ((= (sq-has-sgt sq) 0) (fg% +red+) (write-string "No sergeant."))
              ((= (ss-ok (sq-sgt sq)) 0) (fg% +red+) (write-string "Shell shock — unfit."))
              (t (fg% +grn+) (format t "Active — ~A" (pd-effect-str (aref +pers-defs+ (ss-pers (sq-sgt sq))))))) (rst%)
        (at% 3 41) (fg% +wht+) (bold%) (write-string " PERSONNEL FILE") (rst%)
        (at% 4 41) (fg% +gry+) (dotimes (_ 38) (write-char #\-)) (rst%)
        (let ((li (sq-lore-idx sq)))
          (when (and (>= li 0) (< li (length +codex+)))
            (let ((c (aref +codex+ li)))
              (at% 5 41) (fg% (ce-title-color c)) (bold%) (write-string (ce-title c)) (rst%)
              (at% 6 41) (fg% +gry+) (dotimes (_ 38) (write-char #\-)) (rst%)
              (let ((rr 7)) (dolist (line (ce-lines c)) (when (<= rr 21) (at% rr 41) (fg% +wht+) (dim%) (ppad line 37) (rst%) (incf rr)))))))
        (draw-hline-mid 22 2 79)
        (at% 22 5) (fg% +yel+) (format t "[1-4] Switch  [~A~A] Prev/Next  [ESC] Back" +sym-lf+ +sym-rt+) (rst%) (flush%)
        (let ((k (read-key)))
          (when (or (eq k :esc) (eq k :Q)) (return))
          (when (and (eq k :left)  (> idx 0)) (decf idx))
          (when (and (eq k :right) (< idx (1- (gs-squad-count *g*)))) (incf idx))
          (when (and (eq k :|1|) (>= (gs-squad-count *g*) 1)) (setf idx 0))
          (when (and (eq k :|2|) (>= (gs-squad-count *g*) 2)) (setf idx 1))
          (when (and (eq k :|3|) (>= (gs-squad-count *g*) 3)) (setf idx 2))
          (when (and (eq k :|4|) (>= (gs-squad-count *g*) 4)) (setf idx 3)))))))

