(defun screen-how-to-play ()
  (let ((page 0) (np (length +htp-pages+)))
    (loop
      (cls%)
      (let ((p (aref +htp-pages+ page)))
        (at% 1 1) (fg% +blu+) (bold%) (write-string +tl+) (loop for i from 2 below +tw+ do (write-string +bh+)) (write-string +tr+) (rst%)
        (at% 1 3) (fg% (hp-title-color p)) (bold%) (format t " HOW TO PLAY  ~A  ~40A  ~A  pg ~D/~D" +vt+ (hp-title p) +vt+ (1+ page) np) (rst%)
        (at% 2 1) (fg% +blu+) (bold%) (write-string +lm+) (loop for i from 2 below +tw+ do (write-string +bh+)) (write-string +rm+) (rst%)
        (loop for r from 3 to 21 do (at% r 1) (fg% +blu+) (bold%) (write-string +bv+) (rst%) (at% r +tw+) (fg% +blu+) (bold%) (write-string +bv+) (rst%))
        (let ((row 3))
          (dolist (ln (hp-lines p))
            (when (<= row 21)
              (at% row 3)
              (cond
                ((and (>= (length ln) 1) (char= (char ln 0) #\~))
                 (if (and (>= (length ln) 2) (char= (char ln 1) #\Space))
                     (progn (fg% (hp-title-color p)) (bold%) (format t "  ~A" (subseq ln 2)) (rst%))
                     (progn (fg% +gry+) (dim%) (dotimes (_ (- +tw+ 4)) (write-char #\-)) (rst%))))
                ((and (>= (length ln) 1) (char= (char ln 0) #\|))
                 (fg% +gry+) (write-string "  ") (rst%)
                 (let ((ci 0))
                   (loop for ci2 from 1 below (length ln) do
                         (let ((ch (char ln ci2)))
                           (if (char= ch #\|) (progn (write-char #\Space) (fg% +gry+) (write-char #\|) (rst%) (write-char #\Space) (incf ci))
                               (progn (fg% (if (evenp ci) +wht+ +gry+)) (write-char ch) (rst%)))))))
                (t (fg% +wht+) (write-string "  ") (write-string ln) (rst%)))
              (incf row))))
        (at% 22 1) (fg% +blu+) (bold%) (write-string +lm+) (loop for i from 2 below +tw+ do (write-string +bh+)) (write-string +rm+) (rst%)
        (at% 22 3)
        (loop for i below np do
              (if (= i page) (progn (fg% (hp-title-color p)) (bold%) (write-string +sym-bl+)) (progn (fg% +gry+) (dim%) (write-string +sym-ci+))) (rst%))
        (at% 22 (- +tw+ 46)) (fg% +yel+) (format t "[~A] Prev  [~A] Next  [1-9][0] Jump  [ESC] Back" +sym-lf+ +sym-rt+) (rst%)
        (at% 23 1) (fg% +blu+) (bold%) (write-string +bl+) (loop for i from 2 below +tw+ do (write-string +bh+)) (write-string +br+) (rst%)
        (flush%)
        (let ((k (read-key)))
          (when (or (eq k :esc) (eq k :Q)) (return))
          (when (or (eq k :left) (eq k :up))    (setf page (mod (+ page (1- np)) np)))
          (when (or (eq k :right) (eq k :down)) (setf page (mod (1+ page) np)))
          (loop for digit from 1 to 9 do (when (eq k (intern (write-to-string digit) :keyword)) (setf page (1- digit))))
          (when (eq k :|0|) (setf page 9)))))))

;;; ── Screen: Codex ────────────────────────────────────────────────
(defun screen-codex (start)
  (let ((idx (clamp start 0 (1- (length +codex+)))))
    (loop
      (let ((c (aref +codex+ idx)))
        (cls%) (draw-box 1 2 23 79) (at% 1 4) (fg% +yel+) (bold%)
        (format t " CODEX  ~A  ~D/~D  ~A  ~38A" +vt+ (1+ idx) (length +codex+) +vt+ (ce-title c)) (rst%)
        (draw-hline-mid 2 2 79)
        (at% 4 5) (fg% (ce-title-color c)) (bold%) (write-string (ce-title c)) (rst%)
        (at% 5 5) (fg% +gry+) (dotimes (_ 72) (write-char #\-)) (rst%)
        (let ((r 7)) (dolist (line (ce-lines c)) (when (<= r 20) (at% r 5) (fg% +wht+) (write-string line) (rst%) (incf r))))
        (draw-hline-mid 21 2 79)
        (at% 22 5) (fg% +yel+) (format t "[~A] Prev  [~A] Next  [1-9] Jump  [ESC] Back" +sym-lf+ +sym-rt+) (rst%) (flush%)
        (let ((k (read-key)))
          (when (or (eq k :esc) (eq k :Q)) (return))
          (when (or (eq k :left) (eq k :up))    (setf idx (mod (+ idx (1- (length +codex+))) (length +codex+))))
          (when (or (eq k :right) (eq k :down)) (setf idx (mod (1+ idx) (length +codex+))))
          (loop for digit from 1 to 9 do (when (eq k (intern (write-to-string digit) :keyword)) (let ((ji (1- digit))) (when (< ji (length +codex+)) (setf idx ji))))))))))

;;; ── Screen: Diary ────────────────────────────────────────────────
(defun screen-diary ()
  (let ((scroll 0) (mns #("Jan" "Feb" "Mar" "Apr" "May" "Jun" "Jul" "Aug" "Sep" "Oct" "Nov" "Dec")) (md #(31 28 31 30 31 30 31 31 30 31 30 31)))
    (loop
      (cls%) (draw-box 1 2 23 79) (at% 1 4) (fg% +yel+) (bold%) (format t " FIELD DIARY  ~A  ~D entries" +vt+ (gs-diary-count *g*)) (rst%)
      (draw-hline-mid 2 2 79)
      (let ((vis 16) (total (gs-diary-count *g*)))
        (loop for i below vis do
              (let ((ei (- total 1 (+ scroll i))))
                (at% (+ 3 i) 2) (fg% +blu+) (bold%) (write-string +bv+) (rst%)
                (at% (+ 3 i) 79) (fg% +blu+) (bold%) (write-string +bv+) (rst%)
                (when (and (>= ei 0) (< ei total))
                  (at% (+ 3 i) 3)
                  (let* ((e (aref (gs-diary *g*) ei)) (days (floor (1- (de-turn e)) 2)) (mo 0) (d days))
                    (loop while (and (< mo 11) (>= d (aref md mo))) do (decf d (aref md mo)) (incf mo))
                    (fg% +gry+) (format t " T~3D ~A ~2D ~3A  " (de-turn e) (if (= (de-half-am e) 1) "AM" "PM") (1+ d) (aref mns mo)) (rst%)
                    (fg% +wht+) (ppad (de-text e) (- +tw+ 22)) (rst%)))))
        (draw-hline-mid 20 2 79)
        (at% 21 4) (fg% +gry+) (format t " ~D-~D of ~D" (- total scroll) (max 1 (- total (+ scroll vis -1))) total) (rst%)
        (at% 22 4) (fg% +yel+) (format t "[~A~A] Scroll  [ESC] Back" +sym-up+ +sym-dn+) (rst%) (flush%)
        (let ((k (read-key)))
          (when (or (eq k :esc) (eq k :Q)) (return))
          (when (and (eq k :down) (< (+ scroll vis) total)) (incf scroll))
          (when (and (eq k :up) (> scroll 0)) (decf scroll)))))))

;;; ── Screen: Save/Load ────────────────────────────────────────────
(defun screen-save-load (is-save)
  (let* ((metas (loop for i below +save-slots+ collect (save-meta-read i))) (sel 0))
    (loop
      (cls%) (draw-box 6 12 (+ 6 (* +save-slots+ 2) 3) 68)
      (at% 6 14) (fg% +yel+) (bold%) (write-string (if (= is-save 1) " SAVE GAME — Choose a slot" " LOAD GAME — Choose a slot")) (rst%)
      (draw-hline-mid 7 12 68)
      (loop for i below +save-slots+ do
            (let* ((m (nth i metas)) (disabled (and (= is-save 0) (null m)))
                   (text (if m (format nil "Slot ~D  |  ~A" (1+ i) (getf m :label)) (format nil "Slot ~D  |  (empty)" (1+ i)))))
              (at% (+ 8 (* i 2)) 14)
              (cond (disabled (dim%) (fg% +gry+)) ((= i sel) (fg% +yel+) (bold%)) (t (fg% +wht+)))
              (format t "~A ~A" (if (= i sel) "► " "  ") text) (rst%)))
      (at% (+ 8 (* +save-slots+ 2)) 14) (fg% +gry+) (format t "[~A~A] Nav  [ENTER] Select  [ESC] Cancel" +sym-up+ +sym-dn+) (rst%) (flush%)
      (let ((k (read-key)))
        (when (eq k :esc) (return -1))
        (when (eq k :up)   (loop do (setf sel (mod (+ sel (1- +save-slots+)) +save-slots+)) while (and (= is-save 0) (null (nth sel metas)))))
        (when (eq k :down) (loop do (setf sel (mod (1+ sel) +save-slots+)) while (and (= is-save 0) (null (nth sel metas)))))
        (when (and (eq k :enter) (or (= is-save 1) (nth sel metas))) (return sel))))))
;;; ── Screen: Difficulty ───────────────────────────────────────────
(defun screen-difficulty ()
  ;; Box rows 3-16 cols 8-72: 4 diffs x 2 rows each, subtitle on second row
  (let ((sel 1))
    (loop
      (cls%) (draw-box 3 8 16 72)
      (at% 3 10) (fg% +yel+) (bold%) (write-string " SELECT DIFFICULTY") (rst%)
      (draw-hline-mid 4 8 72)
      (loop for i below +diff-count+ do
            (let* ((dd (aref +diff-defs+ i)) (s (= i sel)))
              (at% (+ 5 (* i 2)) 11)
              (if s (progn (fg% (dd-color dd)) (bold%) (format t "► ~14A" (dd-name dd)))
                    (progn (fg% +gry+) (format t "  ~14A" (dd-name dd))))
              (rst%)
              (at% (+ 6 (* i 2)) 13)
              (fg% (if s +wht+ +gry+)) (dim%)
              (let ((sub (dd-subtitle dd)))
                (write-string (subseq sub 0 (min (length sub) 57))))
              (rst%)))
      (draw-hline-mid 14 8 72)
      (at% 15 11) (fg% +gry+) (format t "[~A~A] Nav  [ENTER] Confirm  [ESC] Back" +sym-up+ +sym-dn+) (rst%) (flush%)
      (let ((k (read-key)))
        (when (eq k :esc) (return +diff-normal+))
        (when (eq k :up)   (setf sel (mod (+ sel (1- +diff-count+)) +diff-count+)))
        (when (eq k :down) (setf sel (mod (1+ sel) +diff-count+)))
        (when (eq k :enter) (return sel))))))

;;; ── Screen: Main Menu ────────────────────────────────────────────
(defun screen-main-menu ()
  (let* ((any-save (loop for i below +save-slots+ thereis (save-meta-read i)))
         (sel 0)
         (opts #("New Campaign" "Load Game" "How to Play" "Codex & Lore" "Credits" "Quit"))
         (n 6))
    (loop
      (cls%)
      (at% 2 18) (fg% +yel+) (bold%)
      (write-string +tl+) (loop for i below 44 do (write-string +bh+)) (write-string +tr+)
      (at% 3 18) (format t "~A  B U R D E N   O F   C O M M A N D      ~A" +bv+ +bv+)
      (at% 4 18) (format t "~A     A  W W I  T r e n c h  T y c o o n  ~A" +bv+ +bv+)
      (at% 5 18) (write-string +bl+) (loop for i below 44 do (write-string +bh+)) (write-string +br+)
      (rst%)
      (at% 6 22) (fg% +gry+)
      (format t "11th East Lancashire Regt.  ~A  Passchendaele  ~A  1917" +vt+ +vt+) (rst%)
      (let* ((bw 40) (br (1+ (floor (- +tw+ bw) 2))))
        (draw-box 8 br (+ 8 (* n 2) 2) (+ br bw -1))
        (loop for i below n do
              (let* ((row (+ 9 (* i 2))) (disabled (and (= i 1) (not any-save))))
                (at% row (+ br 2))
                (cond (disabled (dim%) (fg% +gry+) (format t "    ~A" (aref opts i)))
                      ((= i sel) (fg% +yel+) (bold%) (format t "  ► ~A" (aref opts i)))
                      (t (fg% +wht+) (format t "    ~A" (aref opts i))))
                (rst%)))
        (draw-hline-mid (+ 8 (* n 2) 1) br (+ br bw -1))
        (at% (+ 9 (* n 2)) (+ br 4)) (fg% +gry+)
        (format t "[~A~A] Nav  [ENTER] Select" +sym-up+ +sym-dn+) (rst%) (flush%))
      (let* ((disabled? (lambda (i) (and (= i 1) (not any-save)))) (k (read-key)))
        (when (or (eq k :Q) (eq k :esc)) (return 5))
        (when (eq k :up)   (loop do (setf sel (mod (+ sel (1- n)) n)) while (funcall disabled? sel)))
        (when (eq k :down) (loop do (setf sel (mod (1+ sel) n))      while (funcall disabled? sel)))
        (when (and (eq k :enter) (not (funcall disabled? sel))) (return sel))))))

;;; ── Screen: Pause Menu ───────────────────────────────────────────
(defun screen-pause-menu ()
  (let* ((ironman (= (gs-difficulty *g*) +diff-ironman+))
         (opts #("Resume" "How to Play" "Save Game" "Load Game" "Codex & Lore"
                 "Field Diary" "Squad Dossier" "Trench Upgrades" "Quit to Main Menu"))
         (n 9) (sel 0))
    (loop
      (cls%)
      (let* ((bw 52) (br (1+ (floor (- +tw+ bw) 2))))
        (draw-box 4 br (+ 4 (* n 2) 3) (+ br bw -1))
        (at% 4 (+ br 2)) (fg% +yel+) (bold%)
        (format t " PAUSED  ~A  11th East Lancashire Regt." +vt+) (rst%)
        (draw-hline-mid 5 br (+ br bw -1))
        (loop for i below n do
              (let* ((row (+ 6 (* i 2))) (disabled (and (= i 3) ironman)))
                (at% row (+ br 2))
                (cond (disabled (dim%) (fg% +gry+) (format t "    ~A" (aref opts i)))
                      ((= i sel) (fg% +yel+) (bold%) (format t "  ► ~A" (aref opts i)))
                      (t (fg% +wht+) (format t "    ~A" (aref opts i))))
                (rst%)))
        (at% (+ 6 (* n 2)) (+ br 2)) (fg% +gry+)
        (format t "[~A~A] Nav  [ENTER] Select  [ESC] Resume" +sym-up+ +sym-dn+) (rst%) (flush%)
        (let ((k (read-key)))
          (when (eq k :esc) (return 0))
          (when (eq k :up)   (loop do (setf sel (mod (+ sel (1- n)) n)) while (and (= sel 3) ironman)))
          (when (eq k :down) (loop do (setf sel (mod (1+ sel) n))      while (and (= sel 3) ironman)))
          (when (and (eq k :enter) (not (and (= sel 3) ironman))) (return sel)))))))

;;; ── Screen: Credits ──────────────────────────────────────────────
(defun screen-credits ()
  (cls%) (draw-box 2 8 22 73)
  (let ((lines '((3  22 +yel+ t   "B U R D E N   O F   C O M M A N D")
                 (4  24 +gry+ nil "A WWI Trench Management Tycoon — v4")
                 (6  11 +cyn+ t   "HISTORICAL CONTEXT")
                 (7  11 +wht+ nil "Set during the Third Battle of Ypres (Passchendaele), 1917.")
                 (8  11 +wht+ nil "The 11th East Lancashire Regiment is fictionalised but based")
                 (9  11 +wht+ nil "on the 'Pals Battalions' raised by Lord Derby in 1914-15.")
                 (11 11 +cyn+ t   "THE NUMBERS")
                 (12 11 +wht+ nil "The First World War killed approximately 17 million people.")
                 (13 11 +wht+ nil "A further 20 million were wounded. The war reshaped the world.")
                 (14 11 +wht+ nil "Every statistic was a person. Every person had a name.")
                 (16 11 +cyn+ t   "ON REMEMBRANCE")
                 (17 11 +gry+ nil "This game is offered as a small act of memory.")
                 (18 11 +gry+ nil "The men who served in the trenches of the Western Front")
                 (19 11 +gry+ nil "were ordinary people placed in extraordinary circumstances.")
                 (20 11 +gry+ nil "They endured. Many did not return. None should be forgotten.")
                 (22 28 +grn+ t   "Press any key to return."))))
    (dolist (l lines)
      (destructuring-bind (r c col bold text) l
        (at% r c) (when bold (bold%)) (fg% (symbol-value col))
        (write-string text) (rst%))))
  (flush%) (read-key))

;;; ── Screen: End ──────────────────────────────────────────────────
(defun screen-end ()
  (cls%)
  (let* ((men (total-men))
         (maxm (loop for i below (gs-squad-count *g*) sum (sq-maxm (aref (gs-squads *g*) i))))
         (pct (if (zerop maxm) 0 (floor (* 100 men) maxm)))
         (score (calc-score)) (grade (score-grade score))
         (ei (case (gs-over *g*) (#.+over-win+ 0) (#.+over-lose+ 1) (t 2)))
         (banners #("      ARMISTICE!  YOUR UNIT HAS BEEN RELIEVED.      "
                    "          YOUR COMPANY HAS BEEN ANNIHILATED.         "
                    "              THE MEN HAVE MUTINIED.                  "))
         (lines1 #("Captain Thorne — you endured the unendurable."
                   "The mud of Flanders claimed them all."
                   "Despair consumed what artillery could not."))
         (cols (vector +grn+ +red+ +mag+))
         (col (aref cols ei)))
    ;; Banner rows 2-4
    (at% 2 8) (fg% col) (bold%)
    (write-string +tl+) (loop for i below 62 do (write-string +bh+)) (write-string +tr+)
    (at% 3 8) (format t "~A ~A ~A" +bv+ (aref banners ei) +bv+)
    (at% 4 8) (write-string +bl+) (loop for i below 62 do (write-string +bh+)) (write-string +br+) (rst%)
    ;; Outcome rows 5-6
    (at% 5 10) (fg% col) (write-string (aref lines1 ei)) (rst%)
    (at% 6 10) (fg% +wht+)
    (case (gs-over *g*)
      (#.+over-win+    (format t "~D/~D men survived (~D%)." men maxm pct))
      (#.+over-lose+   (format t "Fell on Week ~D, Turn ~D of ~D." (curr-week) (gs-turn *g*) (gs-maxt *g*)))
      (t               (format t "~D/~D men turned against their officers." men maxm))) (rst%)
    ;; Score row 7
    (at% 7 10) (fg% +cyn+) (bold%) (format t "SCORE: ~D" score) (rst%)
    (at% 7 27) (fg% +yel+) (bold%) (format t "GRADE: ~A" grade) (rst%)
    (at% 7 39) (fg% (dd-color (aref +diff-defs+ (gs-difficulty *g*))))
    (format t "[~A]" (dd-name (aref +diff-defs+ (gs-difficulty *g*)))) (rst%)
    (at% 7 57) (fg% +gry+) (format t "Rep:~D" (gs-hq-rep *g*)) (rst%)
    ;; Report rows 8-12
    (at% 9 10) (fg% +wht+) (bold%) (write-string "CAMPAIGN REPORT") (rst%)
    (at% 10 10) (fg% +gry+) (dotimes (_ 58) (write-char #\-)) (rst%)
    (at% 11 10) (fg% +wht+)
    (format t " Turns: ~D/~D   Men: ~D/~D (~D%%)   Morale: ~D%% ~A"
            (gs-turn *g*) (gs-maxt *g*) men maxm pct (overall-mor) (mor-label (overall-mor))) (rst%)
    (at% 12 10) (fg% +wht+)
    (format t " Medals: ~D   Upgrades: ~D/~D   Rep: ~D/100   Rations: ~A"
            (gs-medals *g*) (popcount% (gs-upgrades *g*)) +upg-count+
            (gs-hq-rep *g*) (rd-name (aref +ration-defs+ (gs-ration-level *g*)))) (rst%)
    ;; Squad summary rows 14-19
    (at% 14 10) (fg% +cyn+) (bold%) (write-string "SQUAD SUMMARY") (rst%)
    (at% 15 10) (fg% +gry+) (dotimes (_ 58) (write-char #\-)) (rst%)
    (loop for i below (min (gs-squad-count *g*) 4) do
          (let ((s (aref (gs-squads *g*) i)))
            (at% (+ 16 i) 10) (fg% +wht+)
            (format t " ~8A  ~D/~D men  Mor:~3D%%  Raids:~2D  Lost:~2D  Wounds:~D"
                    (sq-name s) (sq-men s) (sq-maxm s) (sq-mor s)
                    (sq-raids-repelled s) (sq-men-lost s) (sq-wounds s)) (rst%)))
    (at% 21 10) (fg% +gry+) (write-string "Press any key...") (rst%) (flush%)
    (read-key)))

(defun rand-squad () (aref (gs-squads *g*) (rng-range 0 (1- (gs-squad-count *g*)))))

(defun weakest-sq ()
  (let ((wi 0))
    (loop for i from 1 below (gs-squad-count *g*)
          when (< (sq-mor (aref (gs-squads *g*) i)) (sq-mor (aref (gs-squads *g*) wi))) do (setf wi i))
    (aref (gs-squads *g*) wi)))

(defun largest-sq ()
  (let ((li 0))
    (loop for i from 1 below (gs-squad-count *g*)
          when (> (sq-men (aref (gs-squads *g*) i)) (sq-men (aref (gs-squads *g*) li))) do (setf li i))
    (aref (gs-squads *g*) li)))

(defun record-history ()
  (let ((hi (mod (gs-res-hist-count *g*) +res-hist-len+)))
    (setf (aref (gs-res-hist *g*) hi +res-food+)  (gs-food  *g*))
    (setf (aref (gs-res-hist *g*) hi +res-ammo+)  (gs-ammo  *g*))
    (setf (aref (gs-res-hist *g*) hi +res-meds+)  (gs-meds  *g*))
    (setf (aref (gs-res-hist *g*) hi +res-tools+) (gs-tools *g*))
    (incf (gs-res-hist-count *g*))))

(defun process-evq ()
  (let ((keep 0))
    (loop for i below (gs-ev-count *g*) do
          (let ((e (aref (gs-evq *g*) i)))
            (cond
              ((and (> (gs-convoy-delayed *g*) 0) (= (ev-type e) +ev-supply+))
               (incf (ev-at e)) (decf (gs-convoy-delayed *g*))
               (setf (aref (gs-evq *g*) keep) e) (incf keep))
              ((/= (ev-at e) (gs-turn *g*))
               (setf (aref (gs-evq *g*) keep) e) (incf keep))
              (t (case (ev-type e)
                   (#.+ev-supply+
                    (setf (gs-food  *g*) (clamp (+ (gs-food  *g*) (ev-food  e)) 0 (food-cap)))
                    (setf (gs-ammo  *g*) (clamp (+ (gs-ammo  *g*) (ev-ammo  e)) 0 (ammo-cap)))
                    (setf (gs-meds  *g*) (clamp (+ (gs-meds  *g*) (ev-meds  e)) 0 50))
                    (setf (gs-tools *g*) (clamp (+ (gs-tools *g*) (ev-tools e)) 0 50))
                    (log-msg (format nil "Supply! +~Df +~Da +~Dm +~Dt"
                                     (ev-food e) (ev-ammo e) (ev-meds e) (ev-tools e)))
                    (when (= (gs-supply-req-pending *g*) (gs-turn *g*))
                      (setf (gs-supply-req-pending *g*) -1)))
                   (#.+ev-reinforce+
                    (when (> (gs-squad-count *g*) 0)
                      (let* ((sq (aref (gs-squads *g*) 0))
                             (a (clamp (ev-men e) 0 (- (sq-maxm sq) (sq-men sq)))))
                        (incf (sq-men sq) a)
                        (log-msg (format nil "~D reinforcements join ~A!" a (sq-name sq))))))))))
    (setf (gs-ev-count *g*) keep))))

(defun apply-dispatch (idx comply)
  (let ((d (aref +hq-dispatches+ idx)))
    (setf (gs-dispatch-done *g*) (logior (gs-dispatch-done *g*) (ash 1 idx)))
    (if (= comply 1)
        (progn
          (setf (gs-agg *g*) (clamp (+ (gs-agg *g*) (hd-cy-agg d)) 5 95))
          (loop for i below (gs-squad-count *g*) do
                (setf (sq-mor (aref (gs-squads *g*) i)) (clamp (+ (sq-mor (aref (gs-squads *g*) i)) (hd-cy-all-mor d)) 0 100)))
          (setf (gs-ammo *g*) (clamp (+ (gs-ammo *g*) (hd-cy-ammo d)) 0 (ammo-cap)))
          (setf (gs-food *g*) (clamp (+ (gs-food *g*) (hd-cy-food d)) 0 (food-cap)))
          (when (= (hd-cy-force-raid d) 1) (setf (sq-task (weakest-sq)) +task-raid+))
          (when (= (hd-cy-all-standby d) 1)
            (loop for i below (gs-squad-count *g*) do (setf (sq-task (aref (gs-squads *g*) i)) +task-standby+))
            (setf (gs-forced-standby-turns *g*) 1))
          (when (> (hd-cy-lose-men d) 0)
            (let ((sq (largest-sq)))
              (setf (sq-men sq) (clamp (- (sq-men sq) (hd-cy-lose-men d)) 1 (sq-maxm sq)))))
          (incf (gs-medals *g*) (hd-cy-medals d))
          (setf (gs-hq-rep *g*) (clamp (+ (gs-hq-rep *g*) (hd-cy-rep-delta d)) 0 100))
          (log-msg (format nil "COMPLY: ~A" (hd-comply-result d))))
        (progn
          (setf (gs-agg *g*) (clamp (+ (gs-agg *g*) (hd-df-agg d)) 5 95))
          (loop for i below (gs-squad-count *g*) do
                (setf (sq-mor (aref (gs-squads *g*) i)) (clamp (+ (sq-mor (aref (gs-squads *g*) i)) (hd-df-all-mor d)) 0 100)))
          (setf (gs-hq-rep *g*) (clamp (+ (gs-hq-rep *g*) (hd-df-rep-delta d)) 0 100))
          (when (= idx 1) (setf (gs-convoy-delayed *g*) 3))
          (log-msg (format nil "DEFY: ~A" (hd-defy-result d)))))))

(defun process-historical ()
  (loop for i below (length +hist-events+) do
        (when (and (zerop (logand (gs-hist-fired *g*) (ash 1 i)))
                   (>= (gs-turn *g*) (he-turn (aref +hist-events+ i))))
          (setf (gs-hist-fired *g*) (logior (gs-hist-fired *g*) (ash 1 i)))
          (let ((he (aref +hist-events+ i)))
            (log-msg (he-text he))
            (setf (gs-agg *g*) (clamp (+ (gs-agg *g*) (he-agg-delta he)) 5 95))
            (loop for j below (gs-squad-count *g*) do
                  (setf (sq-mor (aref (gs-squads *g*) j)) (clamp (+ (sq-mor (aref (gs-squads *g*) j)) (he-all-mor-delta he)) 0 100))
                  (setf (sq-fat (aref (gs-squads *g*) j)) (clamp (+ (sq-fat (aref (gs-squads *g*) j)) (he-all-fat-delta he)) 0 100)))
            (when (>= (he-set-weather he) 0) (setf (gs-weather *g*) (he-set-weather he))))))
  (loop for i below (length +hq-dispatches+) do
        (when (and (zerop (logand (gs-dispatch-done *g*) (ash 1 i)))
                   (>= (gs-turn *g*) (hd-turn (aref +hq-dispatches+ i)))
                   (< (gs-dispatch-pending *g*) 0))
          (setf (gs-dispatch-pending *g*) i))))

(defun apply-weather-effects ()
  (let* ((fx (aref +weather-fx+ (gs-weather *g*)))
         (dm (dd-event-mul (aref +diff-defs+ (gs-difficulty *g*))))
         (fat-add (truncate (+ (* (wfx-fat-per-turn fx) dm) 0.5))))
    (when (and (upg-has +upg-duckboards+) (or (= (gs-weather *g*) +weather-rain+) (= (gs-weather *g*) +weather-storm+)))
      (setf fat-add (floor fat-add 2)))
    (loop for i below (gs-squad-count *g*) do
          (setf (sq-fat (aref (gs-squads *g*) i)) (clamp (+ (sq-fat (aref (gs-squads *g*) i)) fat-add) 0 100)))
    (setf (gs-agg *g*) (clamp (+ (gs-agg *g*) (wfx-agg-drift fx)) 5 95))))

(defun apply-notable-passives ()
  (loop for i below (gs-squad-count *g*) do
        (let ((sq (aref (gs-squads *g*) i)))
          (when (> (sq-men sq) 0)
            (let ((cook (find-notable sq +trait-cook+)))
              (when cook (setf (gs-food *g*) (clamp (1+ (gs-food *g*)) 0 (food-cap)))))
            (let ((med (find-notable sq +trait-medic+)))
              (when (and med (> (sq-wounds sq) 0)) (decf (sq-wounds sq)) (setf (gs-meds *g*) (clamp (1- (gs-meds *g*)) 0 50))))
            (let ((scr (find-notable sq +trait-scrounger+)))
              (when scr (if (rng-bool 0.5)
                            (setf (gs-ammo  *g*) (clamp (1+ (gs-ammo  *g*)) 0 (ammo-cap)))
                            (setf (gs-tools *g*) (clamp (1+ (gs-tools *g*)) 0 50)))))
            (let ((mus (find-notable sq +trait-musician+)))
              (when mus (setf (sq-mor sq) (clamp (+ (sq-mor sq) 2) 0 100))))))))

(defun consume ()
  (let* ((fm (* (dd-food-mul (aref +diff-defs+ (gs-difficulty *g*))) (rd-food-mul (aref +ration-defs+ (gs-ration-level *g*)))))
         (fc (+ (truncate (+ (* (clamp (floor (total-men) 6) 1 99) fm) 0.5))
                (wfx-food-extra (aref +weather-fx+ (gs-weather *g*)))))
         (am (ad-ammo-mul (aref +ammo-defs+ (gs-ammo-policy *g*))))
         (ac (loop for i below (gs-squad-count *g*)
                   sum (truncate (+ (* (td-ammo-cost (aref +task-defs+ (sq-task (aref (gs-squads *g*) i)))) am) 0.5))))
         (mc (total-wounds)))
    (setf (gs-food *g*) (clamp (- (gs-food *g*) fc) 0 (food-cap)))
    (setf (gs-ammo *g*) (clamp (- (gs-ammo *g*) ac) 0 (ammo-cap)))
    (setf (gs-meds *g*) (clamp (- (gs-meds *g*) mc) 0 50))
    (let ((ration-mor (rd-mor-per-turn (aref +ration-defs+ (gs-ration-level *g*)))))
      (when (/= ration-mor 0)
        (loop for i below (gs-squad-count *g*) do
              (setf (sq-mor (aref (gs-squads *g*) i)) (clamp (+ (sq-mor (aref (gs-squads *g*) i)) ration-mor) 0 100)))))
    (when (< (gs-food *g*) 15)
      (let ((mm (dd-morale-mul (aref +diff-defs+ (gs-difficulty *g*)))))
        (loop for i below (gs-squad-count *g*) do
              (setf (sq-mor (aref (gs-squads *g*) i)) (clamp (- (sq-mor (aref (gs-squads *g*) i)) (truncate (* 5 mm))) 0 100)))
        (add-msg "CRITICAL: Food exhausted — morale falling!")))
    (when (< (gs-ammo *g*) 10) (add-msg "WARNING: Ammunition nearly depleted!"))
    (when (and (<= (gs-meds *g*) 0) (> (total-wounds) 0)) (add-msg "WARNING: No meds — wounds untreated!"))))

(defun update-squads ()
  (let ((mm (dd-morale-mul (aref +diff-defs+ (gs-difficulty *g*)))))
    (loop for i below (gs-squad-count *g*) do
          (let* ((sq (aref (gs-squads *g*) i))
                 (pm (if (= (sq-has-sgt sq) 1) (pd-mul (aref +pers-defs+ (ss-pers (sq-sgt sq)))) 1.0))
                 (td (aref +task-defs+ (sq-task sq))))
            (incf (sq-turns-alive sq))
            ;; fatigue
            (setf (sq-fat sq) (clamp (+ (sq-fat sq) (truncate (* (td-fat-delta td) pm))) 0 100))
            ;; morale
            (let* ((patrol-mul (if (= (sq-task sq) +task-patrol+) (ad-patrol-mor-mul (aref +ammo-defs+ (gs-ammo-policy *g*))) 1.0))
                   (mor-d (truncate (* (td-mor-delta td) pm patrol-mul))))
              (when (and (= (sq-task sq) +task-patrol+) (upg-has +upg-periscope+)) (incf mor-d 2))
              (when (upg-has +upg-dugout+) (incf mor-d 1))
              (when (and (= (sq-task sq) +task-patrol+) (< (gs-ammo *g*) 20)) (decf mor-d (truncate (* 4 mm))))
              (setf (sq-mor sq) (clamp (+ (sq-mor sq) mor-d) 0 100)))
            ;; resource gains
            (when (> (td-food-gain td)  0) (setf (gs-food  *g*) (clamp (+ (gs-food  *g*) (td-food-gain td))  0 (food-cap))))
            (when (> (td-ammo-gain td)  0) (setf (gs-ammo  *g*) (clamp (+ (gs-ammo  *g*) (td-ammo-gain td))  0 (ammo-cap))))
            (when (> (td-tools-gain td) 0) (setf (gs-tools *g*) (clamp (+ (gs-tools *g*) (td-tools-gain td)) 0 50)))
            ;; high fatigue drain
            (when (> (sq-fat sq) 80) (setf (sq-mor sq) (clamp (- (sq-mor sq) (truncate (* 4 mm))) 0 100)))
            ;; forced standby
            (when (> (gs-forced-standby-turns *g*) 0) (setf (sq-task sq) +task-standby+))
            ;; wound death when no meds
            (when (and (> (sq-wounds sq) 0) (<= (gs-meds *g*) 0) (rng-bool 0.15) (> (sq-men sq) 1))
              (decf (sq-men sq)) (incf (sq-men-lost sq))
              (setf (sq-wounds sq) (clamp (1- (sq-wounds sq)) 0 (sq-men sq)))
              (log-msg (format nil "~A Sq: 1 wounded man dies of infection." (sq-name sq))))
            ;; field hospital auto-heal
            (when (and (upg-has +upg-field-hosp+) (> (sq-wounds sq) 0) (> (gs-meds *g*) 0))
              (decf (sq-wounds sq)) (decf (gs-meds *g*)))
            ;; desertion
            (when (and (< (sq-mor sq) 10) (rng-bool 0.18) (> (sq-men sq) 1))
              (decf (sq-men sq)) (incf (sq-men-lost sq))
              (log-msg (format nil "~A Sq: desertion. Mor ~D." (sq-name sq) (sq-mor sq))))))
    (when (> (gs-forced-standby-turns *g*) 0) (decf (gs-forced-standby-turns *g*)))))

(defun has-supply-queued ()
  (loop for i below (gs-ev-count *g*) thereis (= (ev-type (aref (gs-evq *g*) i)) +ev-supply+)))

(defun push-ev (ev)
  (when (< (gs-ev-count *g*) +max-evq+)
    (setf (aref (gs-evq *g*) (gs-ev-count *g*)) ev)
    (incf (gs-ev-count *g*))))

(defun kill-notable (sq n)
  (when (and n (= (ns-alive n) 1))
    (setf (ns-alive n) 0)
    (log-msg (format nil "~A of ~A Sq. has been killed in action." (ns-name n) (sq-name sq)))))

(defun random-events ()
  (let* ((em (dd-event-mul  (aref +diff-defs+ (gs-difficulty *g*))))
         (mm (dd-morale-mul (aref +diff-defs+ (gs-difficulty *g*))))
         (probs (make-array +revt-count+)))
    (loop for i below +revt-count+ do
          (destructuring-bind (base-prob agg-div) (aref +rand-probs+ i)
            (let* ((base (if (> agg-div 0.0) (/ (gs-agg *g*) agg-div) base-prob))
                   (wm   (if (or (= i +revt-enemy-raid+) (= i +revt-sector-assault+))
                             (wfx-raid-mul (aref +weather-fx+ (gs-weather *g*))) 1.0)))
              (setf (aref probs i) (* base em wm)))))
    (when (upg-has +upg-obs-post+)
      (setf (aref probs +revt-sniper+)     (* (aref probs +revt-sniper+)     0.75))
      (setf (aref probs +revt-enemy-raid+) (* (aref probs +revt-enemy-raid+) 0.75)))
    ;; ARTILLERY
    (when (rng-bool (aref probs +revt-artillery+))
      (let* ((sq (rand-squad)) (cas (rng-range 1 2)))
        (when (upg-has +upg-sandbag+) (setf cas (clamp (1- cas) 0 cas)))
        (when (> (sq-men sq) cas)
          (decf (sq-men sq) cas) (incf (sq-men-lost sq) cas) (incf (sq-wounds sq) cas)
          (setf (sq-mor sq) (clamp (- (sq-mor sq) (truncate (* cas 6 mm))) 0 100))
          (log-msg (format nil "ARTILLERY! ~A Sq: ~D casualt~A, +~DW." (sq-name sq) cas (if (= cas 1) "y" "ies") cas))
          (when (rng-bool 0.25)
            (loop for j below (sq-notable-count sq) do
                  (let ((nb (aref (sq-notables sq) j)))
                    (when (and (= (ns-alive nb) 1) (rng-bool 0.4))
                      (kill-notable sq nb) (return))))))))
    ;; ENEMY RAID
    (when (rng-bool (aref probs +revt-enemy-raid+))
      (let* ((sq (rand-squad))
             (res (+ (aref +raid-resist+ (sq-task sq)) (ad-raid-resist-add (aref +ammo-defs+ (gs-ammo-policy *g*))))))
        (when (upg-has +upg-lewis-nest+)    (incf res 0.15))
        (when (find-notable sq +trait-sharpshooter+) (incf res 0.10))
        (if (rng-bool res)
            (progn (setf (sq-mor sq) (clamp (+ (sq-mor sq) 6) 0 100))
                   (incf (sq-raids-repelled sq))
                   (when (= (sq-raids-repelled sq) 2) (incf (gs-medals *g*)))
                   (when (= (sq-raids-repelled sq) 4) (incf (gs-medals *g*)))
                   (log-msg (format nil "~A Sq repelled enemy raid! Morale up." (sq-name sq))))
            (progn (when (> (sq-men sq) 1) (decf (sq-men sq)) (incf (sq-men-lost sq)) (incf (sq-wounds sq)))
                   (setf (sq-mor sq) (clamp (- (sq-mor sq) (truncate (* 12 mm))) 0 100))
                   (log-msg (format nil "~A Sq: enemy raid broke through! 1 KIA." (sq-name sq)))))))
    ;; GAS
    (when (rng-bool (aref probs +revt-gas+))
      (let ((sq (rand-squad)))
        (if (>= (gs-meds *g*) 5)
            (progn (decf (gs-meds *g*) 5) (log-msg (format nil "GAS ATTACK on ~A. Meds used (-5)." (sq-name sq))))
            (let ((cas (rng-range 1 2)))
              (setf (sq-men sq) (clamp (- (sq-men sq) cas) 0 (sq-maxm sq)))
              (incf (sq-men-lost sq) cas) (incf (sq-wounds sq) cas)
              (log-msg (format nil "GAS ATTACK — no meds! ~D man/men lost." cas))))))
    ;; MAIL
    (when (rng-bool (aref probs +revt-mail+))
      (let ((sq (rand-squad)))
        (setf (sq-mor sq) (clamp (+ (sq-mor sq) (rng-range 4 10)) 0 100))
        (log-msg (format nil "Mail from home cheers ~A Squad." (sq-name sq)))))
    ;; RATS
    (when (and (rng-bool (aref probs +revt-rats+)) (not (upg-has +upg-food-cache+)))
      (let ((lost (rng-range 2 9)))
        (setf (gs-food *g*) (clamp (- (gs-food *g*) lost) 0 (food-cap)))
        (log-msg (format nil "Rats in the stores! ~D rations lost." lost))))
    ;; INFLUENZA
    (when (rng-bool (* (aref probs +revt-influenza+) (if (upg-has +upg-sump+) 0.5 1.0)))
      (let ((sq (rand-squad)))
        (when (> (sq-men sq) 1) (decf (sq-men sq)) (incf (sq-men-lost sq)) (incf (sq-wounds sq)))
        (log-msg (format nil "Influenza: ~A Sq loses 1 man." (sq-name sq)))))
    ;; SGT BREAKDOWN
    (when (rng-bool (aref probs +revt-sgt-breakdown+))
      (let ((sq (rand-squad)))
        (when (and (= (sq-has-sgt sq) 1) (= (ss-ok (sq-sgt sq)) 1))
          (setf (ss-ok (sq-sgt sq)) 0)
          (setf (sq-mor sq) (clamp (- (sq-mor sq) (truncate (* 8 mm))) 0 100))
          (log-msg (format nil "~A has broken down. ~A Sq morale falls." (ss-name (sq-sgt sq)) (sq-name sq))))))
    ;; SUPPLY CONVOY
    (when (and (rng-bool (aref probs +revt-supply-convoy+)) (not (has-supply-queued)))
      (let* ((q (if (>= (gs-hq-rep *g*) 70) 1 0)) (eta (+ (gs-turn *g*) (rng-range 3 7))))
        (loop for i below (gs-squad-count *g*) do
              (when (find-notable (aref (gs-squads *g*) i) +trait-runner+)
                (setf eta (clamp (1- eta) (1+ (gs-turn *g*)) (+ (gs-turn *g*) 8))) (return)))
        (push-ev (make-sev-s :at eta :type +ev-supply+
                   :food  (rng-range (if (= q 1) 15 10) (if (= q 1) 30 20))
                   :ammo  (rng-range (if (= q 1) 12  8) (if (= q 1) 22 15))
                   :meds  (rng-range (if (= q 1)  5  3) (if (= q 1) 10  7))
                   :tools (rng-range (if (= q 1)  4  2) (if (= q 1)  8  5))))
        (log-msg (format nil "HQ: Supply convoy en route. ETA ~D turns." (- eta (gs-turn *g*))))))
    ;; REINFORCE
    (when (rng-bool (aref probs +revt-reinforce+))
      (let ((eta (+ (gs-turn *g*) (rng-range 5 12))))
        (push-ev (make-sev-s :at eta :type +ev-reinforce+ :men (rng-range 1 3)))
        (log-msg (format nil "HQ: Reinforcements en route. ETA ~D turns." (- eta (gs-turn *g*))))))
    ;; SNIPER
    (when (rng-bool (aref probs +revt-sniper+))
      (let ((sq (rand-squad)))
        (when (and (> (sq-men sq) 1) (member (sq-task sq) (list +task-standby+ +task-patrol+ +task-forage+)))
          (let ((ss (find-notable sq +trait-sharpshooter+)))
            (if (and ss (rng-bool 0.5))
                (log-msg (format nil "Sniper targeting ~A Sq — ~A spots him first!" (sq-name sq) (ns-name ss)))
                (progn (decf (sq-men sq)) (incf (sq-men-lost sq)) (incf (sq-wounds sq))
                       (setf (sq-mor sq) (clamp (- (sq-mor sq) (truncate (* 10 mm))) 0 100))
                       (log-msg (format nil "Sniper! ~A Sq: 1 man hit." (sq-name sq)))))))))
    ;; FRATERNIZATION
    (when (and (rng-bool (aref probs +revt-fraternize+)) (or (= (gs-weather *g*) +weather-clear+) (= (gs-weather *g*) +weather-fog+)))
      (loop for i below (gs-squad-count *g*) do
            (setf (sq-mor (aref (gs-squads *g*) i)) (clamp (+ (sq-mor (aref (gs-squads *g*) i)) 6) 0 100)))
      (setf (gs-agg *g*) (clamp (- (gs-agg *g*) 8) 5 95))
      (log-msg "Brief fraternization across no-man's-land. Aggression falls."))
    ;; HERO
    (when (rng-bool (aref probs +revt-hero+))
      (let ((sq (rand-squad)))
        (setf (sq-mor sq) (clamp (+ (sq-mor sq) 10) 0 100))
        (incf (sq-raids-repelled sq))
        (log-msg (format nil "Heroism: a man in ~A Sq distinguishes himself." (sq-name sq)))))
    ;; FRIENDLY FIRE
    (when (rng-bool (aref probs +revt-friendly-fire+))
      (let ((sq (rand-squad)))
        (when (> (sq-men sq) 1) (decf (sq-men sq)) (incf (sq-men-lost sq)) (incf (sq-wounds sq)))
        (setf (sq-mor sq) (clamp (- (sq-mor sq) (truncate (* 15 mm))) 0 100))
        (log-msg (format nil "Friendly fire! ~A Sq: 1 man lost." (sq-name sq)))))
    ;; ENEMY CACHE
    (when (rng-bool (aref probs +revt-cache+))
      (let ((f (rng-range 5 15)))
        (setf (gs-ammo *g*) (clamp (+ (gs-ammo *g*) f) 0 (ammo-cap)))
        (log-msg (format nil "Patrol finds enemy cache! +~D ammo." f))))
    ;; FOOD SPOILAGE
    (when (and (rng-bool (aref probs +revt-food-spoil+)) (not (upg-has +upg-food-cache+)))
      (let ((lost (rng-range 3 12)))
        (setf (gs-food *g*) (clamp (- (gs-food *g*) lost) 0 (food-cap)))
        (log-msg (format nil "Food spoilage! ~D rations lost." lost))))
    ;; AMMO DAMP
    (when (and (rng-bool (aref probs +revt-ammo-damp+)) (not (upg-has +upg-munitions+))
               (or (= (gs-weather *g*) +weather-rain+) (= (gs-weather *g*) +weather-storm+)))
      (let ((lost (rng-range 3 10)))
        (setf (gs-ammo *g*) (clamp (- (gs-ammo *g*) lost) 0 (ammo-cap)))
        (log-msg (format nil "Damp in the ammo crypt! ~D rounds lost." lost))))
    ;; WOUND HEAL
    (when (rng-bool (aref probs +revt-wound-heal+))
      (loop for i below (gs-squad-count *g*) do
            (let ((sq (aref (gs-squads *g*) i)))
              (when (and (> (sq-wounds sq) 0) (> (gs-meds *g*) 0))
                (decf (sq-wounds sq)) (decf (gs-meds *g*))
                (when (zerop (sq-wounds sq)) (log-msg (format nil "~A Sq: all wounds treated." (sq-name sq))))
                (return)))))
    ;; SECTOR ASSAULT
    (when (rng-bool (aref probs +revt-sector-assault+))
      (let ((sec (rng-range 0 3)))
        (setf (aref (gs-sector-threat *g*) sec)
              (clamp (+ (aref (gs-sector-threat *g*) sec) (rng-range 15 30)) 0 100))
        (log-msg (format nil "Enemy pressure rising in Sector ~A." (aref #("A" "B" "C" "D") sec)))))
    ;; Sector threat drift
    (loop for i below 4 do
          (let ((drift (+ (if (> (gs-agg *g*) 60) 1 0) (if (< (gs-agg *g*) 30) -1 0))))
            (when (< i (gs-squad-count *g*))
              (when (or (= (sq-task (aref (gs-squads *g*) i)) +task-patrol+)
                        (= (sq-task (aref (gs-squads *g*) i)) +task-raid+))
                (decf drift 2)))
            (setf (aref (gs-sector-threat *g*) i) (clamp (+ (aref (gs-sector-threat *g*) i) drift) 0 100))))
    (setf (gs-weather *g*) (weather-next (gs-weather *g*)))
    (setf (gs-agg *g*) (clamp (+ (gs-agg *g*) (- (rng-range 0 12) 6)) 5 95))))

(defun check-over ()
  (cond
    ((>= (gs-turn *g*) (gs-maxt *g*)) (setf (gs-over *g*) +over-win+))
    ((zerop (total-men))              (setf (gs-over *g*) +over-lose+))
    (t (loop for i below (gs-squad-count *g*)
             when (>= (sq-mor (aref (gs-squads *g*) i)) 5) do (return-from check-over))
       (setf (gs-over *g*) +over-mutiny+))))

(defun end-turn ()
  (when (= (gs-half-am *g*) 1)
    (let ((bonus (if (upg-has +upg-signal-wire+) 1 0)))
      (setf (gs-cmd-points *g*) (clamp (+ (gs-cmd-points *g*) 1 bonus) 0 (cp-max)))))
  (record-history) (process-evq) (process-historical)
  (apply-weather-effects) (apply-notable-passives) (consume) (update-squads) (random-events)
  (incf (gs-turn *g*))
  (setf (gs-half-am *g*) (if (= (gs-half-am *g*) 1) 0 1))
  (setf (gs-score *g*) (calc-score))
  (check-over))

;;; ── Input Handler ────────────────────────────────────────────────
(defun handle (key)
  (let ((ns (gs-squad-count *g*)) (no +task-count+))
    (if (= (gs-orders-mode *g*) 1)
        (case key
          ((:left :up)    (setf (gs-osel *g*) (mod (+ (gs-osel *g*) (1- no)) no)))
          ((:right :down) (setf (gs-osel *g*) (mod (1+ (gs-osel *g*)) no)))
          (:enter
           (let ((sq (if (< (gs-sel *g*) ns) (aref (gs-squads *g*) (gs-sel *g*)) nil)))
             (when sq (setf (sq-task sq) (aref +order-opts+ (gs-osel *g*)))
                   (log-msg (format nil "Orders: ~A Sq — ~A." (sq-name sq) (td-name (aref +task-defs+ (sq-task sq)))))))
           (setf (gs-orders-mode *g*) 0))
          (:esc (setf (gs-orders-mode *g*) 0))
          (t nil))
        (case key
          ((:up :left)    (setf (gs-sel *g*) (mod (+ (gs-sel *g*) (1- ns)) ns)))
          ((:down :right) (setf (gs-sel *g*) (mod (1+ (gs-sel *g*)) ns)))
          (:space  (end-turn))
          (:O      (setf (gs-orders-mode *g*) 1) (setf (gs-osel *g*) 0))
          (:C      (screen-command))
          (:R      (screen-resources))
          (:I      (screen-intel))
          (:D      (screen-dossier (gs-sel *g*)))
          (:Q      (return-from handle 2))
          (:esc    (return-from handle 1))
          (t nil))))
  0)

;;; ── Main Entry Point ─────────────────────────────────────────────
(defun cleanup ()
  (cls%) (cur-on%)
  #-win32 (when *orig-termios* (sb-posix:tcsetattr 0 sb-posix:tcsanow *orig-termios*))
  #+win32 (raw-off)
  (format t "~%Burden of Command — Thank you for playing.~%Auf Wiedersehen, Captain Thorne.~%~%")
  (finish-output))

(defun main ()
  (raw-on)
  (cur-off%)
  (tagbody
   main-menu
     (let ((choice (screen-main-menu)))
       (cond
         ((= choice 5) (go done))
         ((= choice 2) (screen-how-to-play) (go main-menu))
         ((= choice 3) (screen-codex 0)     (go main-menu))
         ((= choice 4) (screen-credits)     (go main-menu))
         ((= choice 1)
          (let ((slot (screen-save-load 0)))
            (if (< slot 0) (go main-menu)
                (unless (load-slot slot) (add-msg "Failed to load.") (go main-menu)))))
         (t (let ((d (screen-difficulty))) (new-game d)))))
     ;; Main game loop
     (loop while (zerop (gs-over *g*)) do
           (render)
           (when (>= (gs-dispatch-pending *g*) 0)
             (let ((idx (gs-dispatch-pending *g*)))
               (setf (gs-dispatch-pending *g*) -1)
               (let ((comply (screen-hq-dispatch idx)))
                 (apply-dispatch idx comply))))
           (let* ((k (read-key)) (r (handle k)))
             (cond
               ((= r 2) (go main-menu))
               ((= r 1)
                (let ((pm (screen-pause-menu)))
                  (case pm
                    (0 nil)
                    (1 (screen-how-to-play))
                    (2 (let ((s (screen-save-load 1)))
                         (when (>= s 0) (if (save-slot s) (add-msg "Game saved.") (add-msg "Save failed.")))))
                    (3 (let ((s (screen-save-load 0)))
                         (when (and (>= s 0) (not (load-slot s))) (add-msg "Load failed."))))
                    (4 (screen-codex 0))
                    (5 (screen-diary))
                    (6 (screen-dossier (gs-sel *g*)))
                    (7 (screen-upgrades))
                    (8 (go main-menu))))))))
     (when (not (zerop (gs-over *g*))) (screen-end))
     (go main-menu)
   done)
  (cleanup))

(main)
